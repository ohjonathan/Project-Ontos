#!/usr/bin/env bash
# llm-dev — repo-local adopter wrapper for llm-dev-framework (v1.5.0+).
#
# This script is copied verbatim into adopter repos at scripts/llm-dev
# by `scripts/install-adopter.sh`. It resolves the framework checkout
# from .llm-dev/config.yaml so agents never need a hard-wired absolute
# framework path.
#
# Commands:
#   doctor                                 — environment + config health check
#                                            accepts --intent for Gemini cutoff advisories
#   new <deliverable-id>                   — scaffold manifest + tracker
#   verify <manifest-path>                 — run framework verify-adopter.sh
#                                            (manifest conformance only;
#                                            does NOT prove lifecycle
#                                            execution or reviewer dispatch)
#   verify-lifecycle <manifest-path>       — run framework verify-lifecycle.sh
#                                            in --mode strict-p3 by default;
#                                            v1.8.0+ accepts --mode
#                                            provider-limited-fallback for
#                                            honest fallback verification
#                                            (issue #5 + issue #10)
#   re-adjudication list|verify <manifest> — v1.8.0+ inspect or validate
#                                            the manifest's
#                                            re_adjudication_queue[]
#                                            (issue #10)
#   record-fallback-receipt --manifest ...  — append a hash-bound
#                                            provider-limited fallback
#                                            receipt for a declared
#                                            blocked family/provider
#   rebind-artifact --result ...           — validate and rebind a dispatch
#                                            result row to a moved artifact
#   repair-redispatch --manifest ...       — mark redispatch supersession
#                                            and optionally freeze shared
#                                            captures to capture-specific
#                                            paths
#   post-merge --pr ... --branch ...       — reconcile/report PR branch
#                                            reachability after merge
#   review-chain report <manifest>         — non-gating review-chain depth
#                                            report
#   verify-live-docs [--policy <path>]     — stale live-doc phrase sweep
#   verify-authoring-constraints ...       — v1.10.3 scoped authoring
#                                            scanner
#   verify-post-d6-scope ...               — v1.10.3 post-D.6 drift gate
#   verify-handoff-base ...                — v1.10.3 stale-base preflight
#   strict-p3-commands <manifest-path>      — v1.9.0+ emit canonical final
#                                            verification commands for a
#                                            strict-P3 lifecycle
#   goal-card <kind> ...                    — emit a bounded, non-evidence
#                                            goal-mode launch card for a
#                                            human orchestrator
#   capability assess ...                  — run advisory model capability
#                                            assessment for route tuples
#   generate-overlays --target ... --out ... — emit non-evidence runtime
#                                            overlay packages for skills,
#                                            plugins, and extensions
#                                            (codex|claude|gemini|agy|all)
#   update --to latest|vX.Y.Z|<ref>        — re-pin framework checkout
#   agents install                         — insert/refresh AGENTS.md block
#
# Environment overrides:
#   LLM_DEV_CONFIG  — path to config (default: <repo-root>/.llm-dev/config.yaml)

set -euo pipefail

START_MARKER="<!-- llm-dev-framework:start -->"
END_MARKER="<!-- llm-dev-framework:end -->"
CUSTOM_START_MARKER="<!-- USER CUSTOM -->"
CUSTOM_END_MARKER="<!-- /USER CUSTOM -->"

usage() {
  cat <<'USAGE'
usage:
  scripts/llm-dev doctor [--manifest <path>] [--intent <path>]
  scripts/llm-dev new <deliverable-id>
  scripts/llm-dev verify <manifest-path>
  scripts/llm-dev verify-lifecycle [--mode strict-p3|provider-limited-fallback]
                                    [--allow-warn] [--explain-recovery]
                                    <manifest-path>
  scripts/llm-dev verify-staging [--manifest <path>] [--expect <p>] ...
                                  [--forbid <p>] ... [--summary-untracked]
  scripts/llm-dev re-adjudication <list|verify> <manifest-path>
  scripts/llm-dev record-fallback-receipt --manifest <path>
                                  --inventory <path>
                                  --phase <phase> --role <role>
                                  --family <blocked-family>
                                  [--round <n>]
                                  --from-failed-dispatch <result.yaml>
                                  --dispatch-id <id>
                                  [--re-adjudication-ref <id>]
  scripts/llm-dev rebind-artifact --result <path> --dispatch-id <id>
                                  --artifact <path> --reason <text>
  scripts/llm-dev repair-redispatch --manifest <path> --old-run-id <id>
                                    --new-run-id <id> --reason <text>
                                    --issue-ref <ref>
                                    [--freeze-new-captures]
  scripts/llm-dev post-merge --pr <number> --branch <branch> [--verify-all]
  scripts/llm-dev review-chain report <manifest-path>
  scripts/llm-dev verify-live-docs [--policy <path>]
  scripts/llm-dev verify-authoring-constraints <proximity|ac-impl-detail|token-scope> ...
  scripts/llm-dev verify-post-d6-scope --base <git-ref> <path>...
  scripts/llm-dev verify-handoff-base --handoff <path> [--repo <path>]
  scripts/llm-dev strict-p3-commands <manifest-path>
  scripts/llm-dev goal-card <orchestrator|worker|continuation|verify> [...]
  scripts/llm-dev review-seats [--check] [--phase <id>] <manifest-path>
  scripts/llm-dev gate-preflight <manifest-path> [--category <name>] [--all]
  scripts/llm-dev lint-artifact [--family <fam>] [--require-h1] [--json]
                                [--print-contract] [<artifact-path>|-]
  scripts/llm-dev append-supplemental-review --inventory <path> --manifest <path>
                                  --result <dispatch-result.yaml>
                                  --capture-id <id>
                                  --provider-overlap-basis <family>
                                  --rationale <text>
                                  [--manifest-ref <id>] [--round <n>]
  scripts/llm-dev capability assess [--mode inventory|live|fixture]
                                    [--include-primary] [...]
  scripts/llm-dev generate-overlays --target codex|claude|gemini|agy|all
                                    --out <dir> [--force]
                                    [--agy-import-manifest <path>]
  scripts/llm-dev update --to latest|vX.Y.Z|<ref>
  scripts/llm-dev agents install
  scripts/llm-dev --help

Note:
  `verify`            — manifest conformance only (does not prove
                        lifecycle execution or reviewer dispatch).
  `verify-lifecycle`  — strict-P3 lifecycle receipt verification (the
                        gate that proves real multi-family review +
                        verifier dispatch happened — see issue #5).
                        v1.8.0+ accepts --mode provider-limited-fallback
                        for honest fallback verification (issue #10).
  `verify-staging`    — (v1.7.1+) inspects git index + working tree +
                        framework-submodule state against expected /
                        forbidden paths BEFORE commit and before D.6
                        final approval.
  `re-adjudication`   — (v1.8.0+) inspect or validate the manifest's
                        re_adjudication_queue[] (issue #10).
  `record-fallback-receipt` — append a provider-limited-fallback
                        receipt for a manifest-declared blocked
                        family/provider. Verifies a pre-existing
                        failed dispatch row, recomputes blockage
                        evidence hashes, and writes a fallback dispatch
                        bundle; never emits strict-P3 candidate receipts.
  `rebind-artifact`   — validate a moved review artifact and update the
                        matching dispatch-result row with its new path/hash.
  `repair-redispatch` — mark an older receipt superseded by a later round
                        with an issue reference, and with
                        --freeze-new-captures, copy the new prompt/raw/stderr
                        evidence to capture-specific immutable paths.
  `post-merge`        — fetch origin/main, fast-forward local main when
                        safe, check branch reachability, and run default
                        post-merge validations.
  `review-chain`      — non-gating review family/round depth report.
  `verify-live-docs`  — stale live-doc phrase sweep with version-aware
                        historical allowlists; extend with --policy,
                        docs/live-docs-policy.yaml, or
                        .llm-dev/live-docs-policy.yaml.
  `verify-authoring-constraints` — scoped token/proximity/AC drift
                        scanner for v1.10.3 gate authors.
  `verify-post-d6-scope` — rejects post-D.6 normative-looking edits
                        without re-review or non-normative disposition.
  `verify-handoff-base` — fetches remote main and rejects stale handoff
                        base SHAs before implementation begins.
  `strict-p3-commands` — (v1.9.0+) print canonical verifier command
                        blocks derived from the manifest, so handoffs
                        do not drift on argument shape (issue #11).
  `goal-card`         — emit a bounded, non-evidence goal-mode launch
                        aid for a human orchestrator. Goal cards do not
                        create evidence, certify review, or alter
                        lifecycle, D.6, merge, or release authority.
  `review-seats`      — (v1.11.0+) per-phase review-seat table derived
                        from the manifest (issue #64 item 6). Surfaces
                        early that user_facing: true adds a Product
                        reviewer to BOTH design rounds (B.1 AND B.2)
                        plus D.2. --check exits 1 on seat gaps.
  `gate-preflight`    — (v1.11.0+) run the manifest's gate environment
                        preflight + forbidden-symbol greps + scope-
                        category gate commands BEFORE D.6 (issue #64
                        item 4: unit tests do not execute manifest
                        gate greps). --all runs every gate category.
  `lint-artifact`     — (v1.11.0+) F35 verdict-shape lint for a
                        captured artifact or candidate stdout BEFORE
                        re-dispatch or receipt append (issue #64
                        item 2). `--family gemini` applies the
                        wrapper's H1 + fence-strip parity;
                        --print-contract prints the canonical
                        expected-shape contract for prompt authors.
  `append-supplemental-review` — (v1.11.0+) record a same-provider
                        supplemental review pass in the receipt
                        inventory's supplemental_reviews[] array
                        (schema_version 4) — visibly separate from
                        strict-P3 receipts, never counted (issue #64
                        item 7).
  `capability assess` — run the RPUX-2 advisory role-capability
                        harness. Default mode inventories Neuralwatt/
                        OpenCode catalogs only; --mode live performs
                        paid model probes and writes raw transcripts
                        under .llm-dev/capability-runs/.
  `generate-overlays` — emit generated, non-evidence skills/plugins/
                        extensions. Rendered prompts and lifecycle
                        receipts remain the only strict-P3 evidence path.

Environment:
  LLM_DEV_CONFIG  Override config path (default: .llm-dev/config.yaml under repo root)
USAGE
}

die() {
  echo "llm-dev: $*" >&2
  exit 1
}

info() {
  echo "llm-dev: $*"
}

find_repo_root() {
  local script_dir script_root cwd_root
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  script_root="$(cd "$script_dir/.." && pwd)"

  # Prefer the repo that owns this copied wrapper. This keeps absolute
  # invocations like `/path/to/repo/scripts/llm-dev doctor` from accidentally
  # binding to the caller's current git repo.
  if [[ -r "$script_root/.llm-dev/config.yaml" ]]; then
    printf '%s\n' "$script_root"
    return
  fi

  if cwd_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    # The same-inode check keeps install-time calls rooted in the wrapper's
    # own repo even before .llm-dev/config.yaml exists.
    if [[ -r "$cwd_root/.llm-dev/config.yaml" || "$cwd_root" -ef "$script_root" ]]; then
      printf '%s\n' "$cwd_root"
      return
    fi
  fi

  printf '%s\n' "$script_root"
}

repo_root="$(find_repo_root)"
config_path="${LLM_DEV_CONFIG:-$repo_root/.llm-dev/config.yaml}"

# Trim a config value: strip inline `# comment`, leading/trailing
# whitespace, and surrounding quotes.
trim_value() {
  sed -E \
    -e 's/[[:space:]]+#.*$//' \
    -e 's/^[[:space:]]+//' \
    -e 's/[[:space:]]+$//' \
    -e 's/^"//' \
    -e 's/"$//' \
    -e "s/^'//" \
    -e "s/'$//"
}

# v1.11.1 (A4): script-level temp-file registry + EXIT trap so aborted
# runs (die, signal) do not leak mktemp files. Register every mktemp
# result with _track_tmp; rm -f on an already-moved file is harmless.
_llm_dev_tmpfiles=()
_track_tmp() {
  _llm_dev_tmpfiles+=("$1")
}
_llm_dev_cleanup() {
  if [[ "${#_llm_dev_tmpfiles[@]}" -gt 0 ]]; then
    rm -f "${_llm_dev_tmpfiles[@]}"
  fi
  return 0
}
trap _llm_dev_cleanup EXIT

config_get() {
  local key="$1"
  [[ -r "$config_path" ]] || return 1
  # v1.11.1 (A5): escape the key before interpolating into the sed ERE.
  # All current callers pass literal keys; this hardens against a
  # future caller passing regex metacharacters (which previously made
  # the pattern silently match nothing or the wrong line).
  local key_escaped
  key_escaped="$(printf '%s' "$key" | sed -e 's@[][\\.*^$()+?{}|/]@\\&@g')"
  sed -n -E "s/^[[:space:]]*${key_escaped}:[[:space:]]*//p" "$config_path" \
    | head -n 1 \
    | trim_value
}

config_required() {
  local key="$1" value
  value="$(config_get "$key" || true)"
  [[ -n "$value" ]] || die "missing required config key '$key' in $config_path"
  printf '%s\n' "$value"
}

abs_path() {
  local p="$1"
  case "$p" in
    /*) printf '%s\n' "$p" ;;
    *)  printf '%s/%s\n' "$repo_root" "$p" ;;
  esac
}

framework_path() {
  abs_path "$(config_required framework_path)"
}

framework_path_or_self() {
  if [[ -r "$config_path" ]]; then
    framework_path
  else
    printf '%s\n' "$repo_root"
  fi
}

manifest_dir() {
  config_get manifest_dir || true
}

# Rewrite a single top-level scalar key in config.yaml. Adds the key
# at the end of the file if it does not already exist.
set_config_value() {
  local key="$1" value="$2" tmp
  [[ -r "$config_path" ]] || die "config not readable at $config_path"
  tmp="$(mktemp)"
  _track_tmp "$tmp"
  awk -v key="$key" -v value="$value" '
    BEGIN { done = 0 }
    $0 ~ "^[[:space:]]*" key ":" {
      print key ": " value
      done = 1
      next
    }
    { print }
    END {
      if (!done) { print key ": " value }
    }
  ' "$config_path" > "$tmp"
  mv "$tmp" "$config_path"
}

resolve_latest_tag() {
  local repo_url="$1" tags
  command -v python3 >/dev/null 2>&1 || die "python3 is required for update --to latest"
  tags="$(git -c protocol.file.allow=always ls-remote --tags --refs "$repo_url" 'v[0-9]*.[0-9]*.[0-9]*' \
            | awk '{print $2}' \
            | sed 's#refs/tags/##')"
  [[ -n "$tags" ]] || die "no semver tags found at $repo_url"
  printf '%s\n' "$tags" | python3 -c '
import re, sys
def key(t):
    m = re.fullmatch(r"v([0-9]+)\.([0-9]+)\.([0-9]+)", t)
    return tuple(int(p) for p in m.groups()) if m else (-1, -1, -1)
tags = [l.strip() for l in sys.stdin if l.strip()]
print(sorted(tags, key=key)[-1])
'
}

checkout_framework_ref() {
  local fw="$1" ref="$2"
  git -C "$fw" fetch --tags --force origin >/dev/null 2>&1 || true
  if git -C "$fw" rev-parse -q --verify "refs/tags/$ref^{commit}" >/dev/null; then
    git -C "$fw" checkout --detach "$ref" >/dev/null
  elif git -C "$fw" rev-parse -q --verify "refs/remotes/origin/$ref^{commit}" >/dev/null; then
    git -C "$fw" checkout --detach "origin/$ref" >/dev/null
  else
    git -C "$fw" checkout --detach "$ref" >/dev/null
  fi
}

wrapper_drift_status() {
  local fw="$1"
  local wrapper="$repo_root/scripts/llm-dev"
  local framework_wrapper="$fw/scripts/llm-dev"
  if [[ ! -r "$framework_wrapper" ]]; then
    printf 'missing-framework-wrapper:%s\n' "$framework_wrapper"
    return
  fi
  if [[ ! -r "$wrapper" ]]; then
    printf 'missing-adopter-wrapper:%s\n' "$wrapper"
    return
  fi
  if cmp -s "$framework_wrapper" "$wrapper"; then
    printf 'ok\n'
  else
    printf 'drift:%s:%s\n' "$wrapper" "$framework_wrapper"
  fi
}

refresh_adopter_wrapper() {
  local fw="$1"
  local wrapper="$repo_root/scripts/llm-dev"
  local framework_wrapper="$fw/scripts/llm-dev"
  [[ -r "$framework_wrapper" ]] || die "framework wrapper missing at $framework_wrapper"
  mkdir -p "$repo_root/scripts"
  cp "$framework_wrapper" "$wrapper"
  chmod +x "$wrapper"
}

# ---------------------------------------------------------------------------
# doctor
# ---------------------------------------------------------------------------
cmd_doctor() {
  local failed=0
  local fw fw_rel ref repo_url
  local seats_manifest=""
  local cutoff_intent=""

  # (v1.11.0+, issue #64 item 6) optional --manifest appends the
  # review-seat table after the existing checks. No-arg doctor output
  # stays byte-identical. v1.12.1+ optional --intent surfaces the
  # post-cutoff legacy Gemini advisory from cli-probe without dumping
  # the full probe report.
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --manifest)
        shift
        seats_manifest="${1:-}"
        [[ -n "$seats_manifest" ]] || die "doctor: missing path after --manifest"
        ;;
      --intent)
        shift
        cutoff_intent="${1:-}"
        [[ -n "$cutoff_intent" ]] || die "doctor: missing path after --intent"
        ;;
      *)
        die "doctor: unknown argument: $1"
        ;;
    esac
    shift || true
  done

  [[ -r "$config_path" ]] || die "config not found at $config_path (run install-adopter.sh first)"
  fw="$(framework_path)"
  fw_rel="$(config_required framework_path)"
  ref="$(config_get framework_ref || true)"
  repo_url="$(config_get framework_repo_url || true)"

  echo "llm-dev doctor"
  echo "  repo:               $repo_root"
  echo "  config:             ${config_path#$repo_root/}"
  echo "  framework_path:     $fw_rel"
  [[ -n "$ref" ]]      && echo "  framework_ref:      $ref"
  [[ -n "$repo_url" ]] && echo "  framework_repo_url: $repo_url"

  check_cmd() {
    if command -v "$1" >/dev/null 2>&1; then
      echo "  PASS command: $1"
    else
      echo "  FAIL command: $1" >&2
      failed=1
    fi
  }

  check_cmd git
  check_cmd bash
  check_cmd python3
  check_cmd check-jsonschema

  if [[ -d "$fw" && ( -d "$fw/.git" || -f "$fw/.git" || -f "$fw/scripts/verify-adopter.sh" ) ]]; then
    echo "  PASS framework checkout: $fw_rel"
  else
    echo "  FAIL framework checkout missing: $fw_rel" >&2
    failed=1
  fi

  if [[ -x "$fw/scripts/verify-adopter.sh" && -x "$fw/examples/day-one.sh" ]]; then
    echo "  PASS framework scripts (verify-adopter.sh, day-one.sh)"
  else
    echo "  FAIL framework scripts missing or not executable" >&2
    failed=1
  fi

  case "$(wrapper_drift_status "$fw")" in
    ok)
      echo "  PASS adopter wrapper: scripts/llm-dev matches framework copy"
      ;;
    missing-adopter-wrapper:*)
      echo "  FAIL adopter wrapper missing: scripts/llm-dev" >&2
      echo "       run: bash $fw/scripts/install-adopter.sh <repo>  # or scripts/llm-dev update --to ${ref:-latest}" >&2
      failed=1
      ;;
    missing-framework-wrapper:*)
      echo "  FAIL framework wrapper missing: $fw/scripts/llm-dev" >&2
      failed=1
      ;;
    drift:*)
      echo "  FAIL adopter wrapper drift: scripts/llm-dev differs from $fw/scripts/llm-dev" >&2
      echo "       run: scripts/llm-dev update --to ${ref:-latest}" >&2
      failed=1
      ;;
  esac

  for cli in claude codex gemini; do
    if command -v "$cli" >/dev/null 2>&1; then
      echo "  PASS worker CLI: $cli"
    else
      echo "  WARN worker CLI not installed: $cli (review-board phases will need a host with it)"
    fi
  done

  if [[ -n "$seats_manifest" ]]; then
    echo
    bash "$fw/scripts/review-seats.sh" "$(abs_path "$seats_manifest")" || failed=1
  fi

  if [[ -n "$cutoff_intent" ]]; then
    local intent_abs probe_out probe_status warning_lines
    intent_abs="$(abs_path "$cutoff_intent")"
    [[ -r "$intent_abs" ]] || die "doctor: --intent path is not readable: $cutoff_intent"
    probe_out="$(mktemp)"
    _track_tmp "$probe_out"

    echo
    echo "Gemini CLI cutoff advisory:"
    probe_status=0
    bash "$fw/scripts/cli-probe.sh" --intent "$intent_abs" >"$probe_out" 2>&1 || probe_status=$?
    warning_lines="$(grep -F "post-cutoff-legacy-gemini-warning" "$probe_out" || true)"
    if [[ -n "$warning_lines" ]]; then
      printf '%s\n' "$warning_lines"
    elif [[ "$probe_status" -eq 64 ]]; then
      sed -n '/intent-load-failed/p;/invalid LLM_DEV_PROBE_DATE/p;/--intent path/p' "$probe_out" >&2
      failed=1
    else
      echo "  PASS no post-cutoff legacy Gemini warning"
    fi
  fi

  if [[ "$failed" -eq 0 ]]; then
    echo "llm-dev doctor: PASS"
  else
    die "doctor failed"
  fi
}

# ---------------------------------------------------------------------------
# new <deliverable-id>
# ---------------------------------------------------------------------------
cmd_new() {
  local deliverable_id="${1:-}" fw mdir
  [[ -n "$deliverable_id" ]] || die "new requires <deliverable-id>"
  fw="$(framework_path)"
  mdir="$(manifest_dir)"
  [[ -n "$mdir" ]] || mdir="manifests"

  (
    cd "$repo_root"
    MANIFEST_DIR="$(abs_path "$mdir")" bash "$fw/examples/day-one.sh" "$deliverable_id"
  )

  # (v1.11.0+, issue #64 item 6) surface the required review seats at
  # deliverable open — the company-os pr3b1 retro hit the
  # "user_facing forces two design rounds" requirement only at
  # verify-p3 time, far too late.
  local scaffolded
  scaffolded="$(abs_path "$mdir")/$deliverable_id.yaml"
  if [[ -r "$scaffolded" ]]; then
    echo
    bash "$fw/scripts/review-seats.sh" "$scaffolded" || true
    echo
    echo "llm-dev new: if this deliverable is user-facing, set 'user_facing: true' —"
    echo "  that adds a Product reviewer seat to B.1, B.2 AND D.2 (two full design"
    echo "  rounds). Re-run: scripts/llm-dev review-seats $scaffolded"
  fi
}

# ---------------------------------------------------------------------------
# verify <manifest-path>
# ---------------------------------------------------------------------------
cmd_verify() {
  local manifest="${1:-}" fw
  [[ -n "$manifest" ]] || die "verify requires <manifest-path>"
  fw="$(framework_path)"
  bash "$fw/scripts/verify-adopter.sh" "$(abs_path "$manifest")"
}

# ---------------------------------------------------------------------------
# verify-lifecycle <manifest-path> — issue #5 strict-P3 receipt verifier.
#
# Delegates to scripts/verify-lifecycle.sh in --mode strict-p3. Unlike
# `verify`, this command requires the deliverable's lifecycle receipt
# inventory to exist and prove that real multi-family review + verifier
# dispatch happened — D.6 cannot self-attest closure without it.
# ---------------------------------------------------------------------------
cmd_verify_lifecycle() {
  local manifest="" fw allow_warn=0 explain_recovery=0 mode="strict-p3"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --allow-warn) allow_warn=1 ;;
      --mode)
        shift
        mode="${1:-}"
        [[ -n "$mode" ]] || die "verify-lifecycle: missing value after --mode"
        ;;
      --explain-recovery)
        # F35/F36/F37 (v1.7.0, Issue #17): diagnostic flag — classifies
        # each strict-P3 failure into one of eight recovery classes
        # (v1.7.0) or one of thirteen (v1.8.0, Issue #10) and prints
        # the next action. Diagnostic only; no file mutation.
        explain_recovery=1
        ;;
      -h|--help)
        cat <<'USAGE'
usage: scripts/llm-dev verify-lifecycle [--mode strict-p3|provider-limited-fallback]
                                         [--allow-warn]
                                         [--explain-recovery]
                                         <manifest-path>

Run scripts/verify-lifecycle.sh against <manifest-path>. Default mode
is strict-p3. v1.8.0 (Issue #10) adds --mode provider-limited-fallback
for honest fallback verification (mutually exclusive with --allow-warn).

With --explain-recovery, each failure is tagged with a recovery class
(v1.7.0: missing-receipt,
 failed-dispatch-raw-verdict-candidate-available,
 receipt-present-artifact-frontmatter-invalid,
 stderr-throttle-valid-artifact, artifact-summary-stub,
 true-no-evidence, dispatch-attestation-failed,
 parallelism-attestation-missing; v1.8.0 adds
 blocked-family-evidence-missing, fallback-receipt-missing,
 re-adjudication-missing, mechanical-stub-only,
 provider-limited-fallback-incomplete) and a next-action hint.
USAGE
        exit 0
        ;;
      --*)
        die "verify-lifecycle: unknown flag: $1"
        ;;
      *)
        if [[ -z "$manifest" ]]; then
          manifest="$1"
        else
          die "verify-lifecycle: unexpected positional arg: $1"
        fi
        ;;
    esac
    shift || true
  done
  [[ -n "$manifest" ]] || die "verify-lifecycle requires <manifest-path>"
  case "$mode" in
    strict-p3|provider-limited-fallback) ;;
    *) die "verify-lifecycle: unknown --mode $mode (use strict-p3 or provider-limited-fallback)" ;;
  esac
  if [[ "$mode" == "provider-limited-fallback" && "$allow_warn" == "1" ]]; then
    die "verify-lifecycle: --allow-warn is incompatible with --mode provider-limited-fallback"
  fi
  fw="$(framework_path)"
  local args=("$(abs_path "$manifest")" --mode "$mode")
  [[ "$allow_warn" == "1" ]] && args+=(--allow-warn)
  [[ "$explain_recovery" == "1" ]] && args+=(--explain-recovery)
  bash "$fw/scripts/verify-lifecycle.sh" "${args[@]}"
}

# ---------------------------------------------------------------------------
# re-adjudication list|verify <manifest> — v1.8.0 (Issue #10).
#
# Wraps scripts/verify-re-adjudication.sh and provides a friendly
# "list" subcommand that pretty-prints queue items as a table for
# operator triage. Pre-v1.8.0 manifests with no queue block exit
# cleanly.
# ---------------------------------------------------------------------------
cmd_re_adjudication() {
  local sub="" manifest="" fw
  if [[ $# -lt 1 ]]; then
    cat <<'USAGE' >&2
usage: scripts/llm-dev re-adjudication <list|verify> <manifest-path>

  list   — pretty-print manifest.re_adjudication_queue[] entries.
  verify — run scripts/verify-re-adjudication.sh against the manifest.

Pre-v1.8.0 manifests with no queue block exit 0 trivially.
USAGE
    exit 64
  fi
  sub="$1"; shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        echo "usage: scripts/llm-dev re-adjudication <list|verify> <manifest-path>"
        exit 0
        ;;
      --*)
        die "re-adjudication: unknown flag: $1"
        ;;
      *)
        if [[ -z "$manifest" ]]; then
          manifest="$1"
        else
          die "re-adjudication: unexpected positional arg: $1"
        fi
        ;;
    esac
    shift || true
  done
  [[ -n "$manifest" ]] || die "re-adjudication: requires <manifest-path>"
  fw="$(framework_path)"
  case "$sub" in
    verify)
      bash "$fw/scripts/verify-re-adjudication.sh" "$(abs_path "$manifest")"
      ;;
    list)
      python3 - "$(abs_path "$manifest")" <<'PY'
import sys
import yaml

manifest_path = sys.argv[1]
try:
    with open(manifest_path) as f:
        m = yaml.safe_load(f) or {}
except (OSError, yaml.YAMLError) as e:
    print(f"re-adjudication: cannot read manifest: {e}", file=sys.stderr)
    sys.exit(1)

queue = m.get("re_adjudication_queue") or []
if not isinstance(queue, list) or not queue:
    print("re-adjudication: queue is empty or absent")
    sys.exit(0)

headers = ("id", "status", "priority", "blocked_family_ref", "owner", "rerun_trigger")
widths = {h: len(h) for h in headers}
rows = []
for item in queue:
    if not isinstance(item, dict):
        continue
    row = {h: str(item.get(h, "")) for h in headers}
    rows.append(row)
    for h in headers:
        widths[h] = max(widths[h], len(row[h]))

def fmt(row):
    return "  ".join(row[h].ljust(widths[h]) for h in headers)

print(fmt({h: h for h in headers}))
print(fmt({h: "-" * widths[h] for h in headers}))
for row in rows:
    print(fmt(row))

print(f"\nre-adjudication: {len(rows)} item(s)")
PY
      ;;
    *)
      die "re-adjudication: unknown subcommand '$sub' (use list or verify)"
      ;;
  esac
}

cmd_fw_script() {
  local script_name="$1"
  shift
  local fw
  fw="$(framework_path_or_self)"
  case "$script_name" in
    verify-authoring-constraints.py|emit-goal-card.py)
      python3 "$fw/scripts/$script_name" "$@"
      ;;
    *)
      bash "$fw/scripts/$script_name" "$@"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# capability assess — RPUX-2 advisory model capability harness
# ---------------------------------------------------------------------------
cmd_capability() {
  local sub="${1:-}" fw
  if [[ -z "$sub" || "$sub" == "-h" || "$sub" == "--help" ]]; then
    cat <<'USAGE'
usage: scripts/llm-dev capability assess [--mode inventory|live|fixture] [...]

Run the advisory RPUX-2 model capability harness. Default mode inventories
Neuralwatt/OpenCode catalogs and writes a redacted summary; --mode live runs
paid role probes. Scores are recommendations only and never lifecycle evidence.
USAGE
    return 0
  fi
  shift || true
  case "$sub" in
    assess)
      fw="$(framework_path_or_self)"
      python3 "$fw/scripts/model-capability-assess.py" \
        --repo-root "$repo_root" \
        --framework-root "$fw" \
        "$@"
      ;;
    *)
      die "capability: unknown subcommand '$sub' (use assess)"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# record-fallback-receipt --manifest <path> --inventory <path>
#                         --phase <phase> --role <role>
#                         --family <blocked-family>
#                         [--round <n>]
#                         --from-failed-dispatch <result.yaml>
#                         --dispatch-id <id>
#                         [--re-adjudication-ref <id>]
# ---------------------------------------------------------------------------
cmd_record_fallback_receipt() {
  local manifest="" inventory="" phase="" role="" family="" round="1"
  local from_failed_dispatch="" dispatch_id="" re_adjudication_ref=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --manifest) shift; manifest="${1:-}" ;;
      --inventory) shift; inventory="${1:-}" ;;
      --phase) shift; phase="${1:-}" ;;
      --role|--lens) shift; role="${1:-}" ;;
      --family) shift; family="${1:-}" ;;
      --round) shift; round="${1:-}" ;;
      --from-failed-dispatch) shift; from_failed_dispatch="${1:-}" ;;
      --dispatch-id) shift; dispatch_id="${1:-}" ;;
      --re-adjudication-ref) shift; re_adjudication_ref="${1:-}" ;;
      --strict|--strict-p3|--strict-p3-candidate|--strict_p3_candidate)
        die "record-fallback-receipt is fallback-only and never emits strict_p3_candidate=true"
        ;;
      -h|--help)
        cat <<'USAGE'
usage: scripts/llm-dev record-fallback-receipt --manifest <path>
                                  --inventory <path>
                                  --phase <phase> --role <role>
                                  --family <blocked-family>
                                  [--round <n>]
                                  --from-failed-dispatch <result.yaml>
                                  --dispatch-id <id>
                                  [--re-adjudication-ref <id>]

Appends one provider_limited_fallback receipt for a manifest-declared
blocked family/provider. The command verifies a pre-existing failed
dispatch row against the manifest blockage evidence, recomputes the
evidence sha256, writes a generator-owned fallback dispatch bundle, and
never emits strict-P3 candidate receipts.
USAGE
        exit 0
        ;;
      *) die "record-fallback-receipt: unknown argument: $1" ;;
    esac
    shift || true
  done
  [[ -n "$manifest" && -n "$inventory" && -n "$phase" && -n "$role" && -n "$family" ]] \
    || die "record-fallback-receipt requires --manifest, --inventory, --phase, --role, and --family"
  if [[ -z "$from_failed_dispatch" || -z "$dispatch_id" ]]; then
    die "record-fallback-receipt requires --from-failed-dispatch and --dispatch-id so fallback receipts cannot self-create failed attempts"
  fi
  python3 - \
    "$repo_root" \
    "$(abs_path "$manifest")" \
    "$(abs_path "$inventory")" \
    "$phase" "$role" "$family" "$round" \
    "${from_failed_dispatch:+$(abs_path "$from_failed_dispatch")}" \
    "$dispatch_id" "$re_adjudication_ref" <<'PY'
import atexit
import datetime as dt
import hashlib
import os
import re
import sys
import tempfile
import time
from pathlib import Path

import yaml

repo = Path(sys.argv[1]).resolve()
manifest_path = Path(sys.argv[2]).resolve()
inventory_path = Path(sys.argv[3]).resolve()
phase = sys.argv[4].strip()
role = sys.argv[5].strip()
family = sys.argv[6].strip()
round_text = sys.argv[7].strip() or "1"
from_failed_path = Path(sys.argv[8]).resolve() if sys.argv[8].strip() else None
dispatch_id_arg = sys.argv[9].strip()
re_adj_arg = sys.argv[10].strip()

ID_RE = re.compile(r"^[A-Za-z0-9._-]+$")
SHA_RE = re.compile(r"^(?:sha256:)?([0-9a-f]{64})$")
PROVIDER_EQUIVALENCE = {
    "codex": "openai",
    "gpt": "openai",
    "claude": "anthropic",
    "gemini": "google",
}


def fail(message):
    raise SystemExit(f"record-fallback-receipt: {message}")


def load_yaml(path):
    try:
        return yaml.safe_load(path.read_text()) or {}
    except (OSError, yaml.YAMLError) as exc:
        fail(f"cannot read YAML {path}: {exc}")


def sha256_file(path):
    h = hashlib.sha256()
    with path.open("rb") as fh:
        for chunk in iter(lambda: fh.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def normalize_sha(value):
    if not isinstance(value, str):
        return ""
    value = value.strip()
    m = SHA_RE.match(value)
    return m.group(1) if m else ""


def atomic_write_text(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", delete=False, dir=str(path.parent)) as tmp:
        tmp.write(text)
        tmp_path = Path(tmp.name)
    tmp_path.replace(path)


def atomic_write_yaml(path, doc):
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", delete=False, dir=str(path.parent)) as tmp:
        yaml.safe_dump(doc, tmp, sort_keys=False)
        tmp_path = Path(tmp.name)
    tmp_path.replace(path)


def acquire_lock(path):
    lock_path = Path(str(path) + ".lock")
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    for _ in range(50):
        try:
            fd = os.open(str(lock_path), os.O_CREAT | os.O_EXCL | os.O_WRONLY)
            with os.fdopen(fd, "w") as fh:
                fh.write(str(os.getpid()))
            atexit.register(lambda: lock_path.exists() and lock_path.unlink())
            return
        except FileExistsError:
            try:
                owner = lock_path.read_text().strip()
                if owner:
                    try:
                        os.kill(int(owner), 0)
                    except ProcessLookupError:
                        lock_path.unlink()
                        continue
                    except (PermissionError, ValueError):
                        pass
            except OSError:
                pass
            time.sleep(0.1)
    fail(f"could not acquire receipt-inventory lock on {lock_path}")


def rel_to_repo(path):
    try:
        return path.resolve().relative_to(repo).as_posix()
    except ValueError:
        fail(f"path must live under repo root: {path}")


def resolve_declared_path(raw):
    if not isinstance(raw, str) or not raw.strip():
        fail("blockage_evidence_path is missing")
    p = Path(raw.strip())
    if p.is_absolute():
        return p.resolve()
    for base in (manifest_path.parent, repo):
        candidate = (base / p).resolve()
        if candidate.exists():
            return candidate
    return (manifest_path.parent / p).resolve()


def provider_of(fam):
    return fam.split("-", 1)[0]


def equivalence_class(stem):
    return PROVIDER_EQUIVALENCE.get(stem, stem)


def phase_covers(entry):
    phases = entry.get("affected_phases") or []
    return isinstance(phases, list) and phase in [str(p).strip() for p in phases]


def role_covers(entry):
    affected_role = (entry.get("affected_role") or "").strip()
    return not affected_role or affected_role == role


def find_blockage(manifest):
    for entry in manifest.get("harness_blocked_families") or []:
        if not isinstance(entry, dict):
            continue
        if (entry.get("family") or "").strip() == family and phase_covers(entry) and role_covers(entry):
            return "family", entry
    stem = provider_of(family)
    family_provider_class = equivalence_class(stem)
    for entry in manifest.get("harness_blocked_providers") or []:
        if not isinstance(entry, dict) or not phase_covers(entry):
            continue
        affected = [str(x).strip() for x in (entry.get("affected_families") or []) if isinstance(x, str)]
        provider = (entry.get("provider") or "").strip()
        provider_class = equivalence_class(provider)
        if affected:
            if family in affected or stem in affected:
                return "provider", entry
            continue
        if provider in {family, stem, family_provider_class} or provider_class == family_provider_class:
            return "provider", entry
    fail(f"no harness_blocked_families[]/harness_blocked_providers[] entry covers family={family!r} phase={phase!r} role={role!r}")


def find_failed_row(path, wanted_dispatch_id):
    doc = load_yaml(path)
    rows = doc.get("results") or []
    if not isinstance(rows, list):
        fail(f"{path} has no results[] list")
    matches = [
        row for row in rows
        if isinstance(row, dict)
        and (row.get("dispatch_id") or "").strip() == wanted_dispatch_id
    ]
    if len(matches) != 1:
        fail(f"expected exactly one dispatch_id={wanted_dispatch_id!r} in {path}, found {len(matches)}")
    row = dict(matches[0])
    if (row.get("family") or "").strip() != family:
        fail(f"failed dispatch family {row.get('family')!r} does not match requested family={family!r}")
    if (row.get("role") or "").strip() != role:
        fail(f"failed dispatch role {row.get('role')!r} does not match requested role={role!r}")
    row_phase = (row.get("phase") or phase).strip()
    if row_phase != phase:
        fail(f"failed dispatch phase {row_phase!r} does not match requested phase={phase!r}")
    status = (row.get("status") or "").strip()
    if status != "failed":
        fail(f"failed dispatch row status={status!r} must be 'failed'")
    try:
        row_exit = int(row.get("exit_code"))
    except (TypeError, ValueError):
        fail(f"failed dispatch row exit_code={row.get('exit_code')!r} is not an integer")
    if row_exit == 0:
        fail("failed dispatch row exit_code=0 is not a failed external attempt")
    method = (row.get("dispatch_method") or "").strip()
    if method != "external-cli":
        fail(f"failed dispatch row dispatch_method={method!r} must be 'external-cli'")
    return row


try:
    receipt_round = int(round_text)
except ValueError:
    fail(f"--round must be an integer, got {round_text!r}")
if receipt_round < 1:
    fail("--round must be >= 1")
for label, value in (("phase", phase), ("role", role), ("family", family)):
    if not value:
        fail(f"{label} is required")
if not ID_RE.match(family):
    fail(f"family {family!r} contains unsafe characters")
for label, value in (("phase", phase), ("role", role)):
    if not ID_RE.match(value):
        fail(f"{label} {value!r} contains unsafe characters")

manifest = load_yaml(manifest_path)
mode = (manifest.get("fallback_evidence_mode") or "strict_p3").strip()
if mode != "provider_limited_fallback":
    fail(
        "manifest fallback_evidence_mode must be provider_limited_fallback; "
        f"got {mode!r}"
    )
deliverable_id = (manifest.get("id") or manifest.get("slug") or "").strip()
if not deliverable_id:
    fail("manifest id/slug is required")

blockage_kind, blockage = find_blockage(manifest)
evidence_rel = (blockage.get("blockage_evidence_path") or "").strip()
evidence_path = resolve_declared_path(evidence_rel)
if not evidence_path.is_file():
    fail(f"blockage evidence file not found: {evidence_rel}")
actual_evidence_sha = sha256_file(evidence_path)
declared_evidence_sha = normalize_sha(blockage.get("blockage_evidence_sha256"))
if declared_evidence_sha != actual_evidence_sha:
    fail(
        "blockage evidence sha mismatch: "
        f"declared={declared_evidence_sha or '<missing>'} actual={actual_evidence_sha}"
    )

blockage_provider = (blockage.get("provider") or provider_of(family)).strip()
provider = provider_of(family)
blocked_ref = (
    (blockage.get("family") or "").strip()
    if blockage_kind == "family"
    else (blockage.get("provider") or provider_of(family)).strip()
)
re_adj_ref = re_adj_arg or (blockage.get("re_adjudication_ref") or "").strip()

now = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
safe_phase = phase.replace(".", "-")
run_id = f"{deliverable_id}-{phase}-{family}-{role}-fallback-r{receipt_round}"
dispatch_id = dispatch_id_arg or f"{deliverable_id}-{safe_phase}-{family}-{role}-fallback"
if not ID_RE.match(dispatch_id):
    fail(f"dispatch_id {dispatch_id!r} contains unsafe characters")
capture_id = f"{dispatch_id}.generated-r{receipt_round}"
bundle_dir = inventory_path.parent / "fallback-receipts" / run_id
intent_path = bundle_dir / "dispatch-intent.yaml"
result_path = bundle_dir / "dispatch-result.yaml"
artifact_path = bundle_dir / "fallback-artifact.md"

failed_row = find_failed_row(from_failed_path, dispatch_id_arg)
failed_artifact_rel = (failed_row.get("artifact_path") or "").strip()
if not failed_artifact_rel:
    fail("failed dispatch row artifact_path is required")
failed_artifact_path = resolve_declared_path(failed_artifact_rel)
if not failed_artifact_path.is_file():
    fail(f"failed dispatch row artifact_path not found: {failed_artifact_rel}")
if failed_artifact_path.resolve() != evidence_path.resolve():
    fail(
        "failed dispatch row artifact_path must match manifest blockage_evidence_path: "
        f"row={failed_artifact_rel!r} manifest={evidence_rel!r}"
    )
failed_artifact_sha = normalize_sha(failed_row.get("artifact_sha256"))
if not failed_artifact_sha:
    fail("failed dispatch row artifact_sha256 must be a lowercase 64-char sha256")
if failed_artifact_sha != actual_evidence_sha:
    fail(
        "failed dispatch row artifact_sha256 must match manifest blockage_evidence_sha256: "
        f"row={failed_artifact_sha} manifest={actual_evidence_sha}"
    )

started_at = failed_row.get("started_at") or now
ended_at = now
prompt_sha = normalize_sha(failed_row.get("prompt_sha256"))
if not prompt_sha:
    fail("failed dispatch row prompt_sha256 must be a lowercase 64-char sha256")
raw_rel = (failed_row.get("raw_output_path") or failed_row.get("transcript_or_log_path") or evidence_rel).strip()
stderr_rel = (failed_row.get("stderr_path") or evidence_rel).strip()
stderr_sha = normalize_sha(failed_row.get("stderr_hash") or failed_row.get("stderr_sha256")) or actual_evidence_sha

artifact_text = f"""---
id: {run_id}
deliverable_id: {deliverable_id}
phase: {phase}
role: {role}
family: {family}
status: completed
provider_limited_fallback: true
canonical_p3_evidence: false
evidence_labels_used: [orchestrator-preflight]
---

# Provider-Limited Fallback Receipt Artifact

## Summary

Generated fallback artifact for blocked family `{family}` in phase `{phase}` role `{role}`.

## Blockage Evidence

- blocked_family_ref: `{blocked_ref}`
- blocked_evidence_path: `{evidence_rel}`
- blocked_evidence_sha256: `{actual_evidence_sha}`
- manifest_provider: `{blockage_provider}`

## Verdict

approve
"""
artifact_rel = rel_to_repo(artifact_path)
artifact_sha = hashlib.sha256(artifact_text.encode()).hexdigest()

intent_doc = {
    "intents": [
        {
            "dispatch_id": dispatch_id,
            "family": family,
            "role": role,
            "phase": phase,
            "deliverable_id": deliverable_id,
            "dispatch_method": "external-cli",
            "expected_provider": provider,
            "expected_cli": family,
            "expected_model": "auto",
            "expected_artifact": artifact_rel,
        }
    ]
}
attempt_row = {
    "dispatch_id": dispatch_id,
    "capture_id": failed_row.get("capture_id") or f"{capture_id}.attempt",
    "family": family,
    "role": role,
    "phase": phase,
    "deliverable_id": deliverable_id,
    "status": failed_row.get("status") or "failed",
    "exit_code": int(failed_row.get("exit_code")),
    "prompt_sha256": prompt_sha,
    "artifact_path": failed_artifact_rel,
    "artifact_sha256": failed_artifact_sha,
    "raw_output_path": raw_rel,
    "stderr_path": stderr_rel,
    "stderr_hash": stderr_sha,
    "started_at": started_at,
    "ended_at": failed_row.get("ended_at") or now,
    "evidence_cap": failed_row.get("evidence_cap") or "orchestrator-preflight",
    "execution_provider": failed_row.get("execution_provider") or provider,
    "execution_cli": failed_row.get("execution_cli") or family,
    "dispatch_method": "external-cli",
    "fallback_reason": failed_row.get("fallback_reason") or f"{family} blocked: {evidence_rel}",
}
fallback_row = {
    "dispatch_id": dispatch_id,
    "capture_id": capture_id,
    "family": family,
    "role": role,
    "phase": phase,
    "deliverable_id": deliverable_id,
    "status": "provider-limited-fallback-complete",
    "exit_code": 0,
    "prompt_sha256": prompt_sha,
    "artifact_path": artifact_rel,
    "artifact_sha256": artifact_sha,
    "raw_output_path": raw_rel,
    "stderr_path": stderr_rel,
    "stderr_hash": stderr_sha,
    "started_at": started_at,
    "ended_at": now,
    "evidence_cap": "orchestrator-preflight",
    "execution_provider": provider,
    "execution_cli": family,
    "dispatch_method": "provider-limited-fallback",
    "fallback_reason": f"{family} declared blocked in {rel_to_repo(manifest_path)}: {evidence_rel}",
}
result_doc = {"results": [attempt_row, fallback_row]}

receipt = {
    "run_id": run_id,
    "dispatch_id": dispatch_id,
    "capture_id": capture_id,
    "deliverable_id": deliverable_id,
    "phase": phase,
    "round": receipt_round,
    "role": role,
    "family": family,
    "actual_executed_family": family,
    "provider": provider,
    "template_id": "record-fallback-receipt",
    "template_version": "1.0.0",
    "prompt_sha256": prompt_sha,
    "input_artifact_sha256": actual_evidence_sha,
    "output_artifact_path": artifact_rel,
    "output_artifact_sha256": artifact_sha,
    "transcript_or_log_path": raw_rel,
    "stderr_path": stderr_rel,
    "stderr_sha256": stderr_sha,
    "started_at": started_at,
    "ended_at": now,
    "exit_code": 0,
    "strict_p3_candidate": False,
    "provider_limited_fallback": True,
    "dispatch_intent_path": rel_to_repo(intent_path),
    "dispatch_result_path": rel_to_repo(result_path),
    "fallback_disclosure": {
        "blocked_family_ref": blocked_ref,
        "blocked_evidence_path": evidence_rel,
        "blocked_evidence_sha256": actual_evidence_sha,
        "fallback_route": "provider-limited fallback receipt generator",
    },
}
if re_adj_ref:
    receipt["fallback_disclosure"]["re_adjudication_ref"] = re_adj_ref

acquire_lock(inventory_path)
if inventory_path.is_file():
    inventory = load_yaml(inventory_path)
else:
    inventory = {"schema_version": 2, "deliverable_id": deliverable_id, "receipts": []}
schema_version = inventory.get("schema_version")
if schema_version is None:
    inventory["schema_version"] = 2
elif not isinstance(schema_version, int) or schema_version < 2:
    fail(f"inventory schema_version={schema_version!r} cannot store fallback_disclosure; use schema_version >= 2")
if (inventory.get("deliverable_id") or "").strip() != deliverable_id:
    fail(
        f"inventory.deliverable_id={inventory.get('deliverable_id')!r} "
        f"does not match manifest id={deliverable_id!r}"
    )
receipts = inventory.get("receipts") or []
if not isinstance(receipts, list):
    fail("inventory receipts must be a list")
for existing in receipts:
    if not isinstance(existing, dict):
        continue
    if (
        (existing.get("phase") or "").strip(),
        (existing.get("role") or "").strip(),
        (existing.get("family") or "").strip(),
        int(existing.get("round") or 1),
    ) == (phase, role, family, receipt_round):
        fail(f"receipt already exists for ({phase}, {role}, {family}, round={receipt_round})")

atomic_write_text(artifact_path, artifact_text)
atomic_write_yaml(intent_path, intent_doc)
atomic_write_yaml(result_path, result_doc)
receipts.append(receipt)
inventory["receipts"] = receipts
atomic_write_yaml(inventory_path, inventory)

print(f"record-fallback-receipt: appended provider_limited_fallback receipt for ({phase}, {role}, {family})")
print(f"record-fallback-receipt: inventory={rel_to_repo(inventory_path)}")
print(f"record-fallback-receipt: dispatch_intent={rel_to_repo(intent_path)}")
print(f"record-fallback-receipt: dispatch_result={rel_to_repo(result_path)}")
PY
}

# ---------------------------------------------------------------------------
# rebind-artifact --result <path> --dispatch-id <id> --artifact <path> --reason <text>
# ---------------------------------------------------------------------------
cmd_rebind_artifact() {
  local result="" dispatch_id="" artifact="" reason=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --result) shift; result="${1:-}" ;;
      --dispatch-id) shift; dispatch_id="${1:-}" ;;
      --artifact) shift; artifact="${1:-}" ;;
      --reason) shift; reason="${1:-}" ;;
      -h|--help)
        echo "usage: scripts/llm-dev rebind-artifact --result <path> --dispatch-id <id> --artifact <path> --reason <text>"
        exit 0
        ;;
      *) die "rebind-artifact: unknown argument: $1" ;;
    esac
    shift || true
  done
  [[ -n "$result" && -n "$dispatch_id" && -n "$artifact" && -n "$reason" ]] \
    || die "rebind-artifact requires --result, --dispatch-id, --artifact, and --reason"
  local fw
  fw="$(framework_path_or_self)"
  python3 - "$repo_root" "$fw" "$(abs_path "$result")" "$dispatch_id" "$(abs_path "$artifact")" "$reason" <<'PY'
import datetime as dt
import hashlib
import sys
import tempfile
from pathlib import Path

import yaml

repo = Path(sys.argv[1]).resolve()
framework = Path(sys.argv[2]).resolve()
sys.path.insert(0, str(framework / "scripts" / "_lib"))
from verdict_shape import classify_verdict_shape  # noqa: E402

result_path = Path(sys.argv[3]).resolve()
dispatch_id = sys.argv[4]
artifact_path = Path(sys.argv[5]).resolve()
reason = sys.argv[6].strip()

if not result_path.is_file():
    raise SystemExit(f"rebind-artifact: result file not found: {result_path}")
if not artifact_path.is_file():
    raise SystemExit(f"rebind-artifact: artifact file not found: {artifact_path}")
try:
    rel_artifact = artifact_path.relative_to(repo)
except ValueError:
    raise SystemExit("rebind-artifact: artifact must live under the adopter root")
try:
    result_path.relative_to(repo)
except ValueError:
    raise SystemExit("rebind-artifact: result file must live under the adopter root")

data = yaml.safe_load(result_path.read_text()) or {}
rows = data.get("results") or []
if not isinstance(rows, list):
    raise SystemExit("rebind-artifact: result YAML has no results[] list")
matches = [row for row in rows if isinstance(row, dict) and row.get("dispatch_id") == dispatch_id]
if len(matches) != 1:
    raise SystemExit(f"rebind-artifact: expected exactly one dispatch_id={dispatch_id!r}, found {len(matches)}")

h = hashlib.sha256()
with artifact_path.open("rb") as fh:
    for chunk in iter(lambda: fh.read(65536), b""):
        h.update(chunk)
row = matches[0]
shape = classify_verdict_shape(artifact_path.read_text(encoding="utf-8", errors="replace"))
if shape.get("shape") != "verdict_shaped":
    missing = "; ".join(str(x) for x in shape.get("missing") or [])
    raise SystemExit(f"rebind-artifact: artifact is not verdict-shaped; refusing status repair ({missing})")

old_status = row.get("status")
row["artifact_path"] = str(rel_artifact)
row["artifact_sha256"] = h.hexdigest()
if old_status != "completed":
    row["status_before_rebind"] = old_status
row["status"] = "completed"
row["artifact_rebind_reason"] = reason
row["artifact_rebound_at"] = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

with tempfile.NamedTemporaryFile("w", delete=False, dir=str(result_path.parent)) as tmp:
    yaml.safe_dump(data, tmp, sort_keys=False)
    tmp_path = Path(tmp.name)
tmp_path.replace(result_path)
print(
    f"rebind-artifact: updated {result_path.relative_to(repo)} dispatch_id={dispatch_id} "
    f"artifact_path={rel_artifact} status={old_status!r}->'completed'"
)
PY
}

# ---------------------------------------------------------------------------
# repair-redispatch --manifest <path> --old-run-id <id> --new-run-id <id>
#                    --reason <text> --issue-ref <ref>
#                    [--freeze-new-captures]
# ---------------------------------------------------------------------------
cmd_repair_redispatch() {
  local manifest="" old_run_id="" new_run_id="" reason="" issue_ref="" freeze_new_captures=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --manifest) shift; manifest="${1:-}" ;;
      --old-run-id) shift; old_run_id="${1:-}" ;;
      --new-run-id) shift; new_run_id="${1:-}" ;;
      --reason) shift; reason="${1:-}" ;;
      --issue-ref) shift; issue_ref="${1:-}" ;;
      --freeze-new-captures) freeze_new_captures=1 ;;
      -h|--help)
        echo "usage: scripts/llm-dev repair-redispatch --manifest <path> --old-run-id <id> --new-run-id <id> --reason <text> --issue-ref <ref> [--freeze-new-captures]"
        exit 0
        ;;
      *) die "repair-redispatch: unknown argument: $1" ;;
    esac
    shift || true
  done
  [[ -n "$manifest" && -n "$old_run_id" && -n "$new_run_id" && -n "$reason" && -n "$issue_ref" ]] \
    || die "repair-redispatch requires --manifest, --old-run-id, --new-run-id, --reason, and --issue-ref"
  python3 - "$repo_root" "$(abs_path "$manifest")" "$old_run_id" "$new_run_id" "$reason" "$freeze_new_captures" "$issue_ref" <<'PY'
import atexit
import datetime as dt
import hashlib
import os
import re
import shutil
import sys
import tempfile
import time
from pathlib import Path

import yaml

repo = Path(sys.argv[1]).resolve()
manifest_path = Path(sys.argv[2]).resolve()
old_run_id = sys.argv[3].strip()
new_run_id = sys.argv[4].strip()
reason = sys.argv[5].strip()
freeze_new_captures = sys.argv[6] == "1"
issue_ref = sys.argv[7].strip()

ID_RE = re.compile(r"^[A-Za-z0-9._-]+$")


def fail(message):
    raise SystemExit(f"repair-redispatch: {message}")


def load_yaml(path):
    try:
        return yaml.safe_load(path.read_text()) or {}
    except (OSError, yaml.YAMLError) as exc:
        fail(f"cannot read YAML {path}: {exc}")


def atomic_write_yaml(path, doc):
    with tempfile.NamedTemporaryFile("w", delete=False, dir=str(path.parent)) as tmp:
        yaml.safe_dump(doc, tmp, sort_keys=False)
        tmp_path = Path(tmp.name)
    tmp_path.replace(path)


def acquire_inventory_lock(path):
    lock_path = Path(str(path) + ".lock")
    for _ in range(50):
        try:
            fd = os.open(str(lock_path), os.O_CREAT | os.O_EXCL | os.O_WRONLY)
            with os.fdopen(fd, "w") as fh:
                fh.write(str(os.getpid()))
            atexit.register(lambda: lock_path.exists() and lock_path.unlink())
            return
        except FileExistsError:
            owner = ""
            try:
                owner = lock_path.read_text().strip()
                if owner and not Path(f"/proc/{owner}").exists():
                    try:
                        os.kill(int(owner), 0)
                    except ProcessLookupError:
                        lock_path.unlink()
                        continue
                    except (PermissionError, ValueError):
                        pass
            except OSError:
                pass
            time.sleep(0.1)
    fail(f"could not acquire receipt-inventory lock on {lock_path}")


def resolve_ref(ref, *bases):
    if not isinstance(ref, str) or not ref.strip():
        return None
    p = Path(ref)
    if p.is_absolute():
        return p.resolve()
    for base in bases:
        candidate = (base / p).resolve()
        if candidate.exists():
            return candidate
    return (bases[0] / p).resolve()


def rel_to_repo(path):
    try:
        return path.resolve().relative_to(repo).as_posix()
    except ValueError:
        fail(f"path must live under adopter root: {path}")


def sha256_file(path):
    h = hashlib.sha256()
    with path.open("rb") as fh:
        for chunk in iter(lambda: fh.read(65536), b""):
            h.update(chunk)
    return h.hexdigest()


def normalize_sha(value):
    if not isinstance(value, str):
        return ""
    value = value.strip()
    if value.startswith("sha256:"):
        value = value[7:]
    if re.fullmatch(r"[0-9a-fA-F]{64}", value):
        return value.lower()
    return ""


def optional_str(value, field):
    if value is None:
        return ""
    if not isinstance(value, str):
        fail(f"{field} must be a string")
    return value.strip()


def parse_round(receipt, label):
    raw = receipt.get("round", 1)
    try:
        value = int(raw)
    except (TypeError, ValueError):
        fail(f"{label} receipt has invalid round={raw!r}")
    if value < 1:
        fail(f"{label} receipt has invalid round={raw!r}")
    return value


def safe_component(value):
    cleaned = re.sub(r"[^A-Za-z0-9._-]+", "-", str(value or "").strip()).strip(".-")
    return cleaned or "capture"


def declared_matches(path, declared, label):
    if not path.is_file():
        fail(f"{label} file not found: {path}")
    if path.is_symlink():
        fail(f"{label} file must be a regular file, not a symlink: {path}")
    try:
        path.resolve().relative_to(repo)
    except ValueError:
        fail(f"{label} file must live under adopter root: {path}")
    actual = sha256_file(path)
    normalized = normalize_sha(declared)
    if normalized and normalized != actual:
        fail(
            f"{label} hash mismatch before freeze: declared={normalized} actual={actual} path={path}"
        )
    return actual


def copy_capture(source, target, label):
    if not source.is_file():
        fail(f"{label} source not found: {source}")
    if source.is_symlink():
        fail(f"{label} source must be a regular file, not a symlink: {source}")
    target.parent.mkdir(parents=True, exist_ok=True)
    if source.resolve() != target.resolve():
        if target.exists() or target.is_symlink():
            fail(f"{label} target already exists; refusing to overwrite: {target}")
        shutil.copyfile(source, target)
    return sha256_file(target)


if not old_run_id or not new_run_id or old_run_id == new_run_id:
    fail("--old-run-id and --new-run-id must be distinct non-empty ids")
if not reason:
    fail("--reason must be non-empty")
if len(reason) < 12:
    fail("--reason must be at least 12 characters")
if not issue_ref or len(issue_ref) < 2:
    fail("--issue-ref must be a non-empty issue, PR, or decision reference")
if not manifest_path.is_file():
    fail(f"manifest not found: {manifest_path}")

manifest = load_yaml(manifest_path)
inventory_ref = manifest.get("lifecycle_receipt_inventory_path")
inventory_path = resolve_ref(inventory_ref, manifest_path.parent, repo)
if inventory_path is None or not inventory_path.is_file():
    fail(f"manifest has no readable lifecycle_receipt_inventory_path: {inventory_ref!r}")

acquire_inventory_lock(inventory_path)
inventory = load_yaml(inventory_path)
receipts = inventory.get("receipts") or []
if not isinstance(receipts, list):
    fail(f"inventory has no receipts[] list: {inventory_path}")

old_receipt = None
new_receipt = None
for receipt in receipts:
    if not isinstance(receipt, dict):
        continue
    rid = optional_str(receipt.get("run_id"), "receipt.run_id")
    if rid == old_run_id:
        old_receipt = receipt
    if rid == new_run_id:
        new_receipt = receipt

if old_receipt is None:
    fail(f"old receipt run_id not found: {old_run_id!r}")
if new_receipt is None:
    fail(f"new receipt run_id not found: {new_run_id!r}")

for field in ("deliverable_id", "phase", "role", "family"):
    old_value = (old_receipt.get(field) or "").strip()
    new_value = (new_receipt.get(field) or "").strip()
    if not old_value or old_value != new_value:
        fail(
            f"old/new receipts must share {field}: "
            f"old={old_value!r} new={new_value!r}"
        )

old_round = parse_round(old_receipt, "old")
new_round = parse_round(new_receipt, "new")
if new_round <= old_round:
    fail(f"new receipt must be a later round: old={old_round} new={new_round}")
if optional_str(new_receipt.get("superseded_by_run_id"), "new receipt superseded_by_run_id"):
    fail(f"new receipt is already superseded by {new_receipt.get('superseded_by_run_id')!r}")

existing_old_target = optional_str(old_receipt.get("superseded_by_run_id"), "old receipt superseded_by_run_id")
if existing_old_target and existing_old_target != new_run_id:
    fail(
        f"old receipt is already superseded by {existing_old_target!r}; "
        f"refusing to retarget to {new_run_id!r}"
    )

now = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
old_receipt["superseded_by_run_id"] = new_run_id
old_receipt.setdefault("superseded_at", now)
old_receipt["supersession_reason"] = reason
old_receipt["supersession_issue_ref"] = issue_ref
old_receipt["supersession_repaired_at"] = now
old_receipt["supersession_repair_tool"] = "scripts/llm-dev repair-redispatch"
supersedes = new_receipt.get("supersedes_run_ids")
if supersedes is None:
    supersedes = []
elif not isinstance(supersedes, list) or not all(isinstance(x, str) and x.strip() for x in supersedes):
    fail("new receipt supersedes_run_ids must be a list of non-empty strings")
if old_run_id not in supersedes:
    supersedes.append(old_run_id)
new_receipt["supersedes_run_ids"] = supersedes
new_receipt["supersession_reason"] = reason
new_receipt["supersession_issue_ref"] = issue_ref
new_receipt["supersession_repaired_at"] = now
new_receipt["supersession_repair_tool"] = "scripts/llm-dev repair-redispatch"

frozen = {}
result_doc = None
result_path = None
matching_row = None

if freeze_new_captures:
    result_ref = new_receipt.get("dispatch_result_path")
    result_path = resolve_ref(result_ref, manifest_path.parent, repo)
    if result_path is None or not result_path.is_file():
        fail(f"new receipt has no readable dispatch_result_path: {result_ref!r}")
    result_doc = load_yaml(result_path)
    rows = result_doc.get("results") or []
    if not isinstance(rows, list):
        fail(f"dispatch result has no results[] list: {result_path}")

    receipt_capture_id = optional_str(new_receipt.get("capture_id"), "new receipt capture_id")
    receipt_dispatch_id = optional_str(new_receipt.get("dispatch_id"), "new receipt dispatch_id")
    if receipt_capture_id and not ID_RE.match(receipt_capture_id):
        fail(f"new receipt capture_id has invalid characters: {receipt_capture_id!r}")
    if receipt_dispatch_id and not ID_RE.match(receipt_dispatch_id):
        fail(f"new receipt dispatch_id has invalid characters: {receipt_dispatch_id!r}")

    def row_family_role_ok(row):
        return (
            optional_str(row.get("family"), "result family")
            == optional_str(new_receipt.get("family"), "new receipt family")
            and optional_str(row.get("role"), "result role")
            == optional_str(new_receipt.get("role"), "new receipt role")
        )

    candidates = []
    if receipt_capture_id:
        candidates = [
            row for row in rows
            if isinstance(row, dict)
            and optional_str(row.get("capture_id"), "result capture_id") == receipt_capture_id
            and row_family_role_ok(row)
        ]
    if not candidates and receipt_dispatch_id:
        candidates = [
            row for row in rows
            if isinstance(row, dict)
            and optional_str(row.get("dispatch_id"), "result dispatch_id") == receipt_dispatch_id
            and row_family_role_ok(row)
        ]
    if not candidates:
        receipt_artifact_sha = normalize_sha(new_receipt.get("output_artifact_sha256"))
        candidates = [
            row for row in rows
            if isinstance(row, dict)
            and row_family_role_ok(row)
            and (
                not receipt_artifact_sha
                or normalize_sha(row.get("artifact_sha256")) == receipt_artifact_sha
            )
        ]
    active_candidates = [row for row in candidates if not row.get("superseded_by_capture_id")]
    if len(active_candidates) == 1:
        matching_row = active_candidates[0]
    elif not active_candidates and candidates:
        fail(
            f"new receipt run_id={new_run_id!r} matches only superseded dispatch-result rows; "
            "refusing to repair against non-active evidence"
        )
    else:
        fail(
            f"expected exactly one new dispatch-result row for run_id={new_run_id!r}; "
            f"found active={len(active_candidates)} total={len(candidates)}"
        )

    row_dispatch_id = optional_str(matching_row.get("dispatch_id"), "result dispatch_id")
    if not receipt_dispatch_id:
        receipt_dispatch_id = row_dispatch_id
        if receipt_dispatch_id:
            new_receipt["dispatch_id"] = receipt_dispatch_id
    if not receipt_dispatch_id:
        receipt_dispatch_id = safe_component(new_run_id)
        matching_row["dispatch_id"] = receipt_dispatch_id
        new_receipt["dispatch_id"] = receipt_dispatch_id

    capture_id = receipt_capture_id or optional_str(matching_row.get("capture_id"), "result capture_id")
    if not capture_id:
        stamp = dt.datetime.now(dt.timezone.utc).strftime("%Y%m%dT%H%M%SZ")
        capture_id = f"{safe_component(receipt_dispatch_id)}.repair.{stamp}"
    if not ID_RE.match(capture_id):
        fail(f"capture_id has invalid characters: {capture_id!r}")
    safe_capture = safe_component(capture_id)
    matching_row["capture_id"] = capture_id
    matching_row["round"] = new_round
    new_receipt["capture_id"] = capture_id

    prompt_ref = matching_row.get("prompt_path")
    prompt_path = resolve_ref(prompt_ref, manifest_path.parent, repo)
    if prompt_path is None or not prompt_path.is_file():
        fail(f"matched result row has no readable prompt_path: {prompt_ref!r}")
    declared_matches(prompt_path, matching_row.get("prompt_sha256"), "prompt")
    declared_matches(prompt_path, new_receipt.get("prompt_sha256"), "receipt prompt")
    prompt_target = prompt_path.parent / f"{safe_capture}.md"
    prompt_hash = copy_capture(prompt_path, prompt_target, "prompt")
    matching_row["prompt_path"] = rel_to_repo(prompt_target)
    matching_row["prompt_sha256"] = f"sha256:{prompt_hash}"
    new_receipt["prompt_sha256"] = prompt_hash
    new_receipt["input_artifact_sha256"] = prompt_hash
    frozen["prompt"] = rel_to_repo(prompt_target)

    raw_ref = matching_row.get("raw_output_path") or new_receipt.get("transcript_or_log_path")
    raw_path = resolve_ref(raw_ref, manifest_path.parent, repo)
    if raw_path is None or not raw_path.is_file():
        fail(f"matched result row has no readable raw_output_path/transcript_or_log_path: {raw_ref!r}")
    declared_matches(raw_path, matching_row.get("raw_output_hash"), "raw output")
    raw_target = raw_path.parent / f"{safe_capture}.raw.txt"
    raw_hash = copy_capture(raw_path, raw_target, "raw output")
    matching_row["raw_output_path"] = rel_to_repo(raw_target)
    matching_row["raw_output_hash"] = f"sha256:{raw_hash}"
    new_receipt["transcript_or_log_path"] = rel_to_repo(raw_target)
    frozen["raw"] = rel_to_repo(raw_target)

    stderr_ref = matching_row.get("stderr_path") or new_receipt.get("stderr_path")
    if stderr_ref:
        stderr_path = resolve_ref(stderr_ref, manifest_path.parent, repo)
        if stderr_path is None or not stderr_path.is_file():
            fail(f"declared stderr capture is not readable: {stderr_ref!r}")
        declared_matches(stderr_path, matching_row.get("stderr_hash"), "stderr")
        declared_matches(stderr_path, new_receipt.get("stderr_sha256"), "receipt stderr")
        stderr_target = stderr_path.parent / f"{safe_capture}.stderr.txt"
        stderr_hash = copy_capture(stderr_path, stderr_target, "stderr")
        matching_row["stderr_path"] = rel_to_repo(stderr_target)
        matching_row["stderr_hash"] = f"sha256:{stderr_hash}"
        new_receipt["stderr_path"] = rel_to_repo(stderr_target)
        new_receipt["stderr_sha256"] = stderr_hash
        frozen["stderr"] = rel_to_repo(stderr_target)

    old_capture = (
        optional_str(old_receipt.get("capture_id"), "old receipt capture_id")
        or optional_str(old_receipt.get("dispatch_id"), "old receipt dispatch_id")
    )
    superseded_capture_ids = set(matching_row.get("supersedes_capture_ids") or [])
    for row in rows:
        if not isinstance(row, dict) or row is matching_row:
            continue
        if optional_str(row.get("dispatch_id"), "result dispatch_id") != receipt_dispatch_id:
            continue
        row_capture = optional_str(row.get("capture_id"), "result capture_id") or optional_str(row.get("dispatch_id"), "result dispatch_id")
        if old_capture and row_capture != old_capture:
            continue
        if not row.get("superseded_by_capture_id"):
            row["superseded_by_capture_id"] = capture_id
            row["superseded_at"] = now
            row["supersession_reason"] = reason
            row["supersession_issue_ref"] = issue_ref
            row["supersession_repaired_at"] = now
            row["supersession_repair_tool"] = "scripts/llm-dev repair-redispatch"
            if row_capture:
                superseded_capture_ids.add(row_capture)
    if superseded_capture_ids:
        matching_row["supersedes_capture_ids"] = sorted(superseded_capture_ids)
    matching_row["supersession_reason"] = reason
    matching_row["supersession_issue_ref"] = issue_ref
    matching_row["supersession_repaired_at"] = now
    matching_row["supersession_repair_tool"] = "scripts/llm-dev repair-redispatch"

if freeze_new_captures and result_path is not None and result_doc is not None:
    atomic_write_yaml(result_path, result_doc)
atomic_write_yaml(inventory_path, inventory)

inventory_label = rel_to_repo(inventory_path) if str(inventory_path).startswith(str(repo)) else str(inventory_path)
print(f"repair-redispatch: superseded {old_run_id} -> {new_run_id} in {inventory_label}")
if freeze_new_captures:
    for label in ("prompt", "raw", "stderr"):
        if label in frozen:
            print(f"repair-redispatch: froze {label}: {frozen[label]}")
    if "stderr" not in frozen:
        print("repair-redispatch: no stderr capture declared on the new receipt/result; skipped stderr freeze")
print("repair-redispatch: old receipt retained as superseded historical evidence; no old bytes were fabricated")
PY
}

# ---------------------------------------------------------------------------
# post-merge --pr <number> --branch <branch> [--verify-all]
# ---------------------------------------------------------------------------
cmd_post_merge() {
  local pr="" branch="" verify_all=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pr) shift; pr="${1:-}" ;;
      --branch) shift; branch="${1:-}" ;;
      --verify-all) verify_all=1 ;;
      -h|--help)
        echo "usage: scripts/llm-dev post-merge --pr <number> --branch <branch> [--verify-all]"
        exit 0
        ;;
      *) die "post-merge: unknown argument: $1" ;;
    esac
    shift || true
  done
  [[ -n "$pr" && -n "$branch" ]] || die "post-merge requires --pr and --branch"
  local post_merge_fail=0
  echo "llm-dev post-merge report"
  echo "  repo:   $repo_root"
  echo "  pr:     #$pr"
  echo "  branch: $branch"
  git -C "$repo_root" rev-parse --short HEAD | sed 's/^/  head:   /'

  echo "  fetch:  origin main"
  if ! git -C "$repo_root" fetch origin main >/dev/null 2>&1; then
    echo "  fetch:  FAILED (origin/main unavailable)"
    post_merge_fail=1
  fi

  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
    echo "  local branch: present"
  else
    echo "  local branch: absent"
  fi
  if git -C "$repo_root" ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1; then
    echo "  remote branch: origin/$branch present"
  else
    echo "  remote branch: origin/$branch absent or origin unavailable"
  fi
  local github_state="" github_merge_commit="" github_head="" github_base="" github_merged_at=""
  if command -v gh >/dev/null 2>&1; then
    local github_meta="" github_summary=""
    github_meta="$(gh pr view "$pr" --json state,mergedAt,mergeCommit,headRefName,baseRefName 2>/dev/null || true)"
    if [[ -n "$github_meta" ]]; then
      github_summary="$(python3 - "$github_meta" <<'PY'
import json
import sys

doc = json.loads(sys.argv[1])
merge_commit = doc.get("mergeCommit") or {}
print("|".join([
    str(doc.get("state") or ""),
    str(merge_commit.get("oid") or ""),
    str(doc.get("headRefName") or ""),
    str(doc.get("baseRefName") or ""),
    str(doc.get("mergedAt") or ""),
]))
PY
)"
      IFS='|' read -r github_state github_merge_commit github_head github_base github_merged_at <<<"$github_summary"
      echo "  github: $github_state head=$github_head base=$github_base mergedAt=$github_merged_at mergeCommit=$github_merge_commit"
    else
      echo "  github: gh could not read PR #$pr"
    fi
  else
    echo "  github: gh not installed; skipped PR metadata"
  fi

  if git -C "$repo_root" show-ref --verify --quiet refs/remotes/origin/main; then
    if git -C "$repo_root" show-ref --verify --quiet refs/heads/main; then
      if git -C "$repo_root" merge-base --is-ancestor main refs/remotes/origin/main; then
        if [[ "$(git -C "$repo_root" branch --show-current)" == "main" ]]; then
          if git -C "$repo_root" merge --ff-only refs/remotes/origin/main >/dev/null; then
            echo "  local main: fast-forwarded to origin/main"
          else
            echo "  local main: fast-forward FAILED"
            post_merge_fail=1
          fi
        else
          if git -C "$repo_root" branch -f main refs/remotes/origin/main >/dev/null; then
            echo "  local main: fast-forwarded to origin/main"
          else
            echo "  local main: fast-forward FAILED"
            post_merge_fail=1
          fi
        fi
      else
        echo "  local main: diverged from origin/main; refusing non-ff update"
        post_merge_fail=1
      fi
    else
      if git -C "$repo_root" branch main refs/remotes/origin/main >/dev/null; then
        echo "  local main: created at origin/main"
      else
        echo "  local main: create FAILED"
        post_merge_fail=1
      fi
    fi
  fi

  local branch_ref=""
  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
    branch_ref="$branch"
  elif git -C "$repo_root" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    branch_ref="refs/remotes/origin/$branch"
  fi
  if git -C "$repo_root" show-ref --verify --quiet refs/heads/main; then
    if [[ -n "$branch_ref" ]] && git -C "$repo_root" merge-base --is-ancestor "$branch_ref" main; then
      echo "  reachability: $branch is contained in local main"
    elif [[ "$github_state" == "MERGED" && -n "$github_merge_commit" ]] \
      && git -C "$repo_root" cat-file -e "$github_merge_commit^{commit}" 2>/dev/null \
      && git -C "$repo_root" merge-base --is-ancestor "$github_merge_commit" main; then
      echo "  reachability: PR merge commit ${github_merge_commit:0:12} is contained in local main (squash/rebase merge accepted)"
    else
      echo "  reachability: $branch is NOT contained in local main"
      post_merge_fail=1
    fi
  else
    echo "  reachability: skipped (local main missing)"
    post_merge_fail=1
  fi

  local fw
  fw="$(framework_path_or_self)"
  echo "  validation: git diff --check"
  git -C "$repo_root" diff --check || post_merge_fail=1
  echo "  validation: verify-schema.sh"
  bash "$fw/scripts/verify-schema.sh" || post_merge_fail=1
  echo "  validation: verify-frontmatter.sh"
  bash "$fw/scripts/verify-frontmatter.sh" || post_merge_fail=1

  echo "  destructive actions: none (fast-forward only)"
  if [[ "$verify_all" -eq 1 ]]; then
    echo "  verify-all: running $fw/scripts/verify-all.sh"
    bash "$fw/scripts/verify-all.sh" || post_merge_fail=1
  fi
  return "$post_merge_fail"
}

# ---------------------------------------------------------------------------
# review-chain report <manifest>
# ---------------------------------------------------------------------------
cmd_review_chain() {
  local sub="${1:-}" manifest="${2:-}"
  [[ "$sub" == "report" && -n "$manifest" ]] || die "usage: scripts/llm-dev review-chain report <manifest-path>"
  python3 - "$repo_root" "$(abs_path "$manifest")" <<'PY'
import sys
from pathlib import Path

import yaml

repo = Path(sys.argv[1]).resolve()
manifest_path = Path(sys.argv[2]).resolve()
manifest = yaml.safe_load(manifest_path.read_text()) or {}
inventory_ref = manifest.get("lifecycle_receipt_inventory_path")
if not inventory_ref:
    print("review-chain: no lifecycle_receipt_inventory_path in manifest")
    raise SystemExit(0)
candidate = Path(inventory_ref)
if not candidate.is_absolute():
    for base in (manifest_path.parent, repo):
        maybe = (base / candidate).resolve()
        if maybe.is_file():
            candidate = maybe
            break
inventory = yaml.safe_load(Path(candidate).read_text()) or {}
rows = inventory.get("receipts") or []
groups = {}
for row in rows:
    if not isinstance(row, dict):
        continue
    key = (row.get("phase") or "", row.get("role") or "")
    groups.setdefault(key, []).append(row)
print(f"review-chain report: {manifest_path.relative_to(repo) if manifest_path.is_relative_to(repo) else manifest_path}")
print(f"inventory: {Path(candidate).relative_to(repo) if Path(candidate).is_relative_to(repo) else candidate}")
for (phase, role), items in sorted(groups.items()):
    families = sorted({str(i.get("family") or "") for i in items if i.get("family")})
    rounds = sorted({int(i.get("round") or 1) for i in items})
    providers = sorted({str(i.get("provider") or "") for i in items if i.get("provider")})
    fallback = sum(1 for i in items if i.get("provider_limited_fallback") or i.get("operator_judged"))
    print(
        f"- {phase or '<none>'} / {role or '<none>'}: "
        f"receipts={len(items)} families={len(families)} providers={len(providers)} "
        f"rounds={','.join(map(str, rounds)) or '-'} fallback={fallback}"
    )
    print(f"  families: {', '.join(families) if families else '-'}")
print("review-chain: report only; no gate decision made")
PY
}

# ---------------------------------------------------------------------------
# verify-live-docs
# ---------------------------------------------------------------------------
cmd_verify_live_docs() {
  local policy=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --policy) shift; policy="${1:-}" ;;
      -h|--help)
        echo "usage: scripts/llm-dev verify-live-docs [--policy <path>]"
        exit 0
        ;;
      *) die "verify-live-docs: unknown argument: $1" ;;
    esac
    shift || true
  done
  python3 - "$repo_root" "$(framework_path_or_self)" "${policy:+$(abs_path "$policy")}" <<'PY'
import sys
import re
from pathlib import Path

import yaml

repo = Path(sys.argv[1]).resolve()
framework = Path(sys.argv[2]).resolve()
# v1.12.0 (C1): the banner-guard text machinery lives in the shared
# _lib module (extracted after the v1.11.1 R2 eleven-round board);
# this command keeps only policy handling and the two banner rules.
# D.4 (D3-3): the import is FAIL-CLOSED — a copied-wrapper layout
# whose framework path lacks _lib must refuse, not fall through to
# whatever modules the adopter root happens to contain (the board
# demonstrated a shim-injection false PASS).
_lib_dir = (framework / "scripts" / "_lib").resolve()
for _required in ("visible_text.py", "semver.py"):
    if not (_lib_dir / _required).is_file():
        raise SystemExit(
            f"verify-live-docs: framework _lib module missing: "
            f"{_lib_dir / _required} — refusing to import from elsewhere "
            f"(check .llm-dev/config.yaml framework_path)"
        )
sys.path.insert(0, str(_lib_dir))
import visible_text as _vt_mod  # noqa: E402
import semver as _semver_mod  # noqa: E402
for _mod in (_vt_mod, _semver_mod):
    _mod_file = Path(getattr(_mod, "__file__", "")).resolve()
    if not str(_mod_file).startswith(str(_lib_dir)):
        raise SystemExit(
            f"verify-live-docs: module {_mod.__name__} resolved outside the "
            f"framework _lib ({_mod_file}) — refusing (fail-closed)"
        )
_visible_text = _vt_mod.visible_text
_first_visible_line = _vt_mod.first_visible_line
version_tuple = _semver_mod.loose_version_tuple

explicit_policy = Path(sys.argv[3]).resolve() if len(sys.argv) > 3 and sys.argv[3] else None
if explicit_policy and not explicit_policy.is_file():
    raise SystemExit(f"verify-live-docs: policy file not found: {explicit_policy}")
roots = [
    # v1.11.1: README.md added — the most visible live doc was the one
    # file the sweep never read (it drifted to two releases stale
    # without a single hit).
    repo / "README.md",
    repo / "CHANGELOG.md",
    repo / "ROADMAP.md",
    repo / "framework.md",
    repo / "playbook.md",
    repo / "tokens.md",
    repo / "templates",
    repo / "docs",
]


def _changelog_current_version():
    """Derive the current released version from CHANGELOG.md.

    v1.11.1: replaces the hardcoded current_version literal, which had
    silently gone two releases stale and neutered every version-aware
    rule. The regex is kept textually identical to the one in
    scripts/verify-version-bump.sh (the suite's existing ground truth
    for CHANGELOG release headings) — update both together.
    """
    changelog = repo / "CHANGELOG.md"
    if not changelog.is_file():
        raise SystemExit(
            "verify-live-docs: CHANGELOG.md not found — cannot derive "
            "current_version (declare one in a live-docs policy file to "
            "override)"
        )
    # D.4 fix for D.2 review ADV-3/D3-4: tolerate en/em/hyphen dashes
    # and a capitalized "(Released" so release-like heading variants
    # cannot fall out of the version-aware rules. Keep textually
    # identical to the three sites in scripts/verify-version-bump.sh.
    # Spec-defined semantics (D.3 ruling on D3-5): the derived version
    # is the TOP released heading — CHANGELOG is newest-first by
    # contract; ordering itself is not validated here.
    heading = re.compile(r"^##\s+v(\d+\.\d+\.\d+)\s+[—–-]\s+(?:Released|.*\((?:Released|released)\b)")
    for line in changelog.read_text(encoding="utf-8", errors="replace").splitlines():
        m = heading.match(line)
        if m:
            return m.group(1)
    raise SystemExit(
        "verify-live-docs: no `## vX.Y.Z — ... (released ...)` heading in "
        "CHANGELOG.md — cannot derive current_version (declare one in a "
        "live-docs policy file to override)"
    )


policy = {
    # D.4 fix for D.2 review PEER-2/ALIGN-1 (D3-2): current_version is
    # derived LAZILY after policy files merge, so an explicit policy
    # value can rescue an underivable CHANGELOG as the diagnostics
    # promise. None = derive after merge.
    "current_version": None,
    # Files whose first non-blank, non-HTML-comment line must name the
    # current version (the README-title drift class). Mergeable from
    # policy files; entries must stay inside the repo (D3-3).
    "required_current_version_banners": [
        "README.md",
    ],
    "excluded_prefixes": [
        "docs/logs",
        "docs/handoffs",
        "docs/retros",
        "docs/trackers",
    ],
    "patterns": [
        {"id": "stale-v1.9.7", "text": "v1.9.7"},
        {"id": "agy-argv-prompt-body", "text": "agy --sandbox --print --print-timeout <duration> <prompt-body>"},
        {"id": "stdin-codex-only", "text": "codex only; else null"},
    ],
    "historical_allow": [
        {
            "id": "stale-v1.9.7",
            "path": "docs/v1.10.0-antigravity-cli-migration-proposal.md",
            "max_target_release": "1.10.0",
        },
        {
            "id": "stale-v1.9.7",
            "path": "docs/specs/v1.9.6-self-receipting-dogfood-readjudication-spec.md",
            "max_target_release": "1.9.6",
        },
    ],
}

def merge_policy_file(path):
    if not path or not path.is_file():
        return
    doc = yaml.safe_load(path.read_text()) or {}
    if not isinstance(doc, dict):
        raise SystemExit(f"verify-live-docs: policy must be a mapping: {path}")
    if doc.get("current_version"):
        policy["current_version"] = str(doc["current_version"])
    for key in ("excluded_prefixes", "patterns", "historical_allow", "required_current_version_banners"):
        if key in doc:
            if not isinstance(doc[key], list):
                raise SystemExit(f"verify-live-docs: policy.{key} must be a list: {path}")
            policy[key].extend(doc[key])

for policy_path in (
    repo / "docs" / "live-docs-policy.yaml",
    repo / ".llm-dev" / "live-docs-policy.yaml",
    explicit_policy,
):
    merge_policy_file(policy_path)

if not policy["current_version"]:
    policy["current_version"] = _changelog_current_version()


def frontmatter_target_release(text):
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return ""
    for line in lines[1:80]:
        if line.strip() == "---":
            break
        if line.startswith("target_release:"):
            return line.split(":", 1)[1].strip().strip('"').strip("'")
    return ""

def is_excluded(rel):
    rel_s = rel.as_posix()
    for prefix in policy["excluded_prefixes"]:
        prefix_s = str(prefix).strip().strip("/")
        if rel_s == prefix_s or rel_s.startswith(prefix_s + "/"):
            return True
    return False

def is_allowed(pattern_id, rel, target_release):
    rel_s = rel.as_posix()
    target_v = version_tuple(target_release)
    current_v = version_tuple(policy["current_version"])
    for entry in policy["historical_allow"]:
        if not isinstance(entry, dict):
            continue
        if entry.get("id") not in (None, pattern_id):
            continue
        if str(entry.get("path") or "").strip().strip("/") != rel_s:
            continue
        max_release = entry.get("max_target_release")
        if max_release and target_v > version_tuple(max_release):
            continue
        min_release = entry.get("min_target_release")
        if min_release and target_v < version_tuple(min_release):
            continue
        expires_after = entry.get("expires_after_current_version")
        if expires_after and current_v > version_tuple(expires_after):
            continue
        return True
    return False

patterns = []
for item in policy["patterns"]:
    if not isinstance(item, dict) or not item.get("id") or not item.get("text"):
        raise SystemExit("verify-live-docs: each policy pattern must include id and text")
    patterns.append((str(item["id"]), str(item["text"])))

files = []
for root in roots:
    if root.is_file():
        files.append(root)
    elif root.is_dir():
        files.extend(p for p in root.rglob("*.md") if p.is_file())

hits = []

# v1.11.1 banner check: the first VISIBLE line of each listed file must
# name the current version. This is the mechanical guard for the
# README-title drift class (title pinned to an old release while the
# CHANGELOG moves on).
#
# D.4 fixes for the D.2 round:
#   - D3-1 (blocker): HTML-comment lines are skipped when selecting the
#     banner line (a hidden `<!-- v1.11.0 -->` above a stale visible
#     title used to satisfy the check), and the version must match with
#     boundaries (a prerelease-looking `v1.11.0-beta` or a longer
#     version containing the needle no longer passes).
#   - D3-3: banner entries are constrained to files inside the repo;
#     absolute or escaping paths fail closed with a named hit instead
#     of reading (and partially disclosing) outside-repo files.
banner_needle = f"v{policy['current_version']}"
# D.4 round-2 fix (ADV-R2-1): '.' in the lookahead too — `v3.1.0.1`
# satisfied the check by prefix when only the lookbehind excluded dots.
banner_rx = re.compile(
    r"(?<![0-9A-Za-z.\-])" + re.escape(banner_needle) + r"(?![0-9A-Za-z.\-])"
)




for rel_name in policy["required_current_version_banners"]:
    banner_rel = Path(str(rel_name))
    if banner_rel.is_absolute():
        hits.append(("stale-version-banner", banner_rel, 0, "banner path must be repo-relative (absolute path rejected)"))
        continue
    banner_path = (repo / banner_rel).resolve()
    try:
        banner_path.relative_to(repo)
    except ValueError:
        hits.append(("stale-version-banner", banner_rel, 0, "banner path escapes the repo (rejected)"))
        continue
    if not banner_path.is_file():
        hits.append(("stale-version-banner", banner_rel, 0, "file missing"))
        continue
    banner_text = banner_path.read_text(encoding="utf-8", errors="replace")
    first_line_no, first_line, first_raw_line = _first_visible_line(banner_text)
    if not banner_rx.search(_visible_text(first_line)):
        hits.append(
            (
                "stale-version-banner",
                banner_rel,
                first_line_no,
                f"{first_raw_line}  [expected {banner_needle} per CHANGELOG.md]",
            )
        )
    else:
        # D.4 round-6 structural rule (board convergence): six closure
        # rounds showed that hidden-syntax stripping is an arms race —
        # every leak vector smuggled the CURRENT version past a STALE
        # visible title. Inverted check: any version-shaped token on
        # the RAW banner line that is not the current version fails,
        # regardless of where it hides. The stale token in the drift
        # class is by definition visible, so this closes the whole
        # leak family structurally; the visible-text approximation
        # above remains as the guard for versionless-title masking.
        any_version_rx = re.compile(
            r"(?<![0-9A-Za-z.\-])v\d+\.\d+\.\d+(?![0-9A-Za-z.\-])"
        )
        # D.4 round-10 fix (ADV-R10-1): the token rule scans the RAW
        # source line, not the block-stripped one — comment/script-
        # embedded conflicting tokens on the banner line must count.
        conflicting = sorted(
            {
                tok
                for tok in any_version_rx.findall(first_raw_line)
                if tok != banner_needle
            }
        )
        if conflicting:
            hits.append(
                (
                    "conflicting-version-token",
                    banner_rel,
                    first_line_no,
                    f"{first_raw_line}  [token(s) {', '.join(conflicting)} conflict with {banner_needle} per CHANGELOG.md]",
                )
            )

for path in sorted(set(files)):
    rel = path.relative_to(repo)
    if is_excluded(rel):
        continue
    text = path.read_text(encoding="utf-8", errors="replace")
    target_release = frontmatter_target_release(text)
    for line_no, line in enumerate(text.splitlines(), 1):
        for label, needle in patterns:
            if needle not in line:
                continue
            if is_allowed(label, rel, target_release):
                continue
            hits.append((label, rel, line_no, line.strip()))

if hits:
    print("verify-live-docs: FAIL")
    for label, rel, line_no, line in hits:
        print(f"  {label}: {rel}:{line_no}: {line}")
    raise SystemExit(1)
print("verify-live-docs: PASS")
PY
}

# ---------------------------------------------------------------------------
# strict-p3-commands <manifest> — v1.9.0 draft (Issue #11).
#
# Emits canonical final verification command blocks from the manifest.
# ---------------------------------------------------------------------------
cmd_strict_p3_commands() {
  local manifest="${1:-}" fw
  [[ -n "$manifest" ]] || die "strict-p3-commands requires <manifest-path>"
  fw="$(framework_path_or_self)"
  bash "$fw/scripts/emit-strict-p3-commands.sh" \
    --adopter-root "$repo_root" \
    --framework-root "$fw" \
    "$(abs_path "$manifest")"
}

# ---------------------------------------------------------------------------
# gate-preflight <manifest> [--category <name>] [--all] — v1.11.0 (issue #64
# item 4). The mechanical "run your manifest grep gates yourself BEFORE
# D.6" surface: gate environment preflight first (halts on
# environment-setup failure so it is never misread as product behavior),
# then the exemption-aware forbidden-symbol scan, then scope-category
# gate commands (--all runs every category).
# ---------------------------------------------------------------------------
cmd_gate_preflight() {
  local manifest="" all=0 fw
  local -a categories=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --category)
        shift
        [[ -n "${1:-}" ]] || die "gate-preflight: missing value after --category"
        categories+=("$1")
        ;;
      --all) all=1 ;;
      -*) die "gate-preflight: unknown argument: $1" ;;
      *)
        [[ -z "$manifest" ]] || die "gate-preflight: multiple manifest paths given"
        manifest="$1"
        ;;
    esac
    shift || true
  done
  [[ -n "$manifest" ]] || die "gate-preflight requires <manifest-path>"
  fw="$(framework_path_or_self)"
  local mpath
  mpath="$(abs_path "$manifest")"

  # --scope gate (issue #64 PR review): only entries declared scope
  # gate|both can block this preflight — verify-gate-commands.sh never
  # executes smoke-scoped entries, so a required smoke-only variable
  # must not block a gate-only run.
  echo "llm-dev gate-preflight: 1/3 gate environment (verify-gate-environment.sh --scope gate)"
  bash "$fw/scripts/verify-gate-environment.sh" --manifest "$mpath" --scope gate \
    || die "gate-preflight halted: environment-setup failure (fix the environment; this is NOT a product-behavior failure)"

  echo
  echo "llm-dev gate-preflight: 2/3 forbidden-symbol scan (grep-forbidden-symbols.sh)"
  bash "$fw/scripts/grep-forbidden-symbols.sh" --manifest "$mpath" \
    || die "gate-preflight halted: forbidden-symbol match on runtime surfaces"

  echo
  if [[ "$all" -eq 1 ]]; then
    echo "llm-dev gate-preflight: 3/3 gate commands (all categories)"
    bash "$fw/scripts/verify-gate-commands.sh" --manifest "$mpath"
  elif [[ ${#categories[@]} -gt 0 ]]; then
    echo "llm-dev gate-preflight: 3/3 gate commands (categories: ${categories[*]})"
    local -a cat_flags=()
    local c
    for c in "${categories[@]}"; do cat_flags+=(--category "$c"); done
    bash "$fw/scripts/verify-gate-commands.sh" --manifest "$mpath" "${cat_flags[@]}"
  else
    echo "llm-dev gate-preflight: 3/3 gate commands (--category scope; use --all for every category)"
    bash "$fw/scripts/verify-gate-commands.sh" --manifest "$mpath" --category scope
  fi
}

# ---------------------------------------------------------------------------
# generate-overlays --target codex|claude|gemini|all --out <dir>
#
# Emits generated runtime overlays only. The output is ergonomic and never
# replaces rendered prompt bytes, lifecycle receipts, or verifier evidence.
# ---------------------------------------------------------------------------
cmd_generate_overlays() {
  local fw
  fw="$(framework_path_or_self)"
  [[ -x "$fw/scripts/generate-overlays.sh" ]] \
    || die "generate-overlays requires an installed framework config or a framework checkout with scripts/generate-overlays.sh"
  bash "$fw/scripts/generate-overlays.sh" "$@"
}

# ---------------------------------------------------------------------------
# verify-staging [flags] — v1.7.1 Workstream E.
#
# Inspects git index + working tree + framework-submodule state against
# expected / forbidden paths BEFORE commit. Delegates to
# scripts/verify-staging.sh with the adopter's auto-resolved roots.
# Default: when the framework is installed under .llm-dev/framework,
# auto-forbids staging under that path (the v1.7.1 Workstream A class
# of bug: artifacts landing in the submodule instead of the adopter
# tree). Adopters opt-in to this check by invoking it; legacy adopters
# remain unaffected.
# ---------------------------------------------------------------------------
cmd_verify_staging() {
  local fw
  fw="$(framework_path)"
  bash "$fw/scripts/verify-staging.sh" \
    --adopter-root "$repo_root" \
    --framework-root "$fw" \
    "$@"
}

# ---------------------------------------------------------------------------
# update --to latest|vX.Y.Z|<ref>
# ---------------------------------------------------------------------------
cmd_update() {
  local to_ref="latest" fw repo_url resolved
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --to)
        shift; to_ref="${1:-}"
        ;;
      -h|--help)
        usage; exit 0
        ;;
      *)
        die "unknown update argument: $1"
        ;;
    esac
    shift || true
  done

  [[ -n "$to_ref" ]] || die "update --to requires a ref"
  fw="$(framework_path)"
  repo_url="$(config_get framework_repo_url || true)"
  [[ -n "$repo_url" ]] || repo_url="$(git -C "$fw" remote get-url origin 2>/dev/null || true)"
  [[ -n "$repo_url" ]] || die "no framework_repo_url in config and no origin in framework checkout"

  if [[ "$to_ref" == "latest" ]]; then
    resolved="$(resolve_latest_tag "$repo_url")"
  else
    resolved="$to_ref"
  fi

  checkout_framework_ref "$fw" "$resolved"
  set_config_value framework_ref "$resolved"
  case "$(wrapper_drift_status "$fw")" in
    ok)
      info "adopter wrapper already matches framework copy"
      ;;
    missing-adopter-wrapper:*|drift:*)
      refresh_adopter_wrapper "$fw"
      info "adopter wrapper refreshed at scripts/llm-dev"
      ;;
    missing-framework-wrapper:*)
      die "updated framework checkout does not contain scripts/llm-dev"
      ;;
  esac

  bash "$fw/scripts/verify-schema.sh" >/dev/null
  bash "$fw/scripts/verify-tokens.sh" >/dev/null

  info "framework checkout updated to $resolved"
  info "next: re-validate each adopter manifest you rely on:"
  info "  bash scripts/llm-dev verify <manifest-path>"
  info "next: review and commit changes:"
  info "  git add .gitmodules ${config_path#$repo_root/} \\"
  info "          $(config_required framework_path)"
}

# ---------------------------------------------------------------------------
# agents install
# ---------------------------------------------------------------------------
agents_block() {
  cat <<'BLOCK'
<!-- llm-dev-framework:start -->
## llm-dev-framework Activation

This repo uses `llm-dev-framework` via the repo-local wrapper at
`scripts/llm-dev`. Resolve the framework checkout from
`.llm-dev/config.yaml`; never hard-code an absolute framework path.

Auto-detect rule:
- If `.llm-dev/config.yaml` exists, run `scripts/llm-dev doctor`
  before planning implementation work, then use the wrapper for
  `new <deliverable-id>` / `verify <manifest>` /
  `update --to latest` / `agents install`.
- If `.llm-dev/config.yaml` is absent, only activate the framework
  when the user explicitly asks for `llm-dev-framework`, `/llm-dev`,
  or "install llm-dev-framework". Do not invent the framework into
  unrelated requests.

Managed by `scripts/llm-dev agents install`. Edit content outside
the start/end markers; the block between markers is overwritten on
every refresh. In an AGENTS.md with a preserved `USER CUSTOM`
section, this block lives inside that section so upstream generators
keep it.
<!-- llm-dev-framework:end -->
BLOCK
}

cmd_agents_install() {
  local action="${1:-}" agents_file agents_target agents_dir block_file tmp has_custom link_target
  [[ "$action" == "install" ]] || die "usage: scripts/llm-dev agents install"

  agents_file="$repo_root/AGENTS.md"
  agents_target="$agents_file"
  if [[ -L "$agents_file" ]]; then
    link_target="$(readlink "$agents_file")" || die "could not read AGENTS.md symlink"
    [[ -n "$link_target" ]] || die "AGENTS.md symlink has an empty target"
    case "$link_target" in
      /*) agents_target="$link_target" ;;
      *)
        agents_dir="$(cd "$(dirname "$agents_file")" && pwd)"
        agents_target="$agents_dir/$link_target"
        ;;
    esac
    [[ -e "$agents_target" ]] || die "AGENTS.md symlink target does not exist: $link_target"
    [[ ! -d "$agents_target" ]] || die "AGENTS.md symlink target is a directory: $link_target"
  else
    if [[ -d "$agents_file" ]]; then
      die "AGENTS.md is a directory; refusing to overwrite it"
    fi
    touch "$agents_file"
  fi
  [[ -w "$agents_target" ]] || die "AGENTS.md is not writable: ${agents_target#$repo_root/}"

  block_file="$(mktemp)"
  _track_tmp "$block_file"
  tmp="$(mktemp)"
  _track_tmp "$tmp"
  agents_block > "$block_file"
  has_custom="$(
    awk \
      -v custom_start="$CUSTOM_START_MARKER" \
      -v custom_end="$CUSTOM_END_MARKER" '
      function normalized(line) {
        sub(/\r$/, "", line)
        sub(/^[ \t]+/, "", line)
        sub(/[ \t]+$/, "", line)
        return line
      }
      function is_fence(line,  clean) {
        clean = line
        sub(/\r$/, "", clean)
        return clean ~ /^[ \t]*(```|~~~)/
      }
      {
        if (is_fence($0)) {
          in_fence = !in_fence
          next
        }
        if (in_fence) next
        marker = normalized($0)
        if (!in_custom && marker == custom_start) {
          in_custom = 1
          next
        }
        if (in_custom && marker == custom_end) {
          found = 1
          exit
        }
      }
      END { print found ? 1 : 0 }
    ' "$agents_target"
  )"

  awk \
    -v start="$START_MARKER" \
    -v end="$END_MARKER" \
    -v custom_start="$CUSTOM_START_MARKER" \
    -v custom_end="$CUSTOM_END_MARKER" \
    -v has_custom="$has_custom" \
    -v block="$block_file" '
    function flush_pending_blanks(  i) {
      for (i = 0; i < pending_blank_count; i++) print ""
      pending_blank_count = 0
    }
    function normalized(line) {
      sub(/\r$/, "", line)
      sub(/^[ \t]+/, "", line)
      sub(/[ \t]+$/, "", line)
      return line
    }
    function is_fence(line,  clean) {
      clean = line
      sub(/\r$/, "", clean)
      return clean ~ /^[ \t]*(```|~~~)/
    }
    function print_block(  line) {
      while ((getline line < block) > 0) print line
      close(block)
    }
    BEGIN {
      in_block = 0
      in_custom = 0
      inserted = 0
      saw_custom_start = 0
      pending_blank_count = 0
    }
    {
      marker = normalized($0)
    }
    in_block {
      if (marker == end) in_block = 0
      next
    }
    is_fence($0) {
      flush_pending_blanks()
      print
      in_fence = !in_fence
      next
    }
    !in_fence && marker == start {
      if (has_custom && !in_custom) {
        # Stale outside block: drop the blank that preceded it so the
        # migrated USER CUSTOM section stays clean.
        pending_blank_count = 0
        in_block = 1
        next
      }
      flush_pending_blanks()
      print_block()
      in_block = 1
      inserted = 1
      next
    }
    !in_fence && marker == custom_start {
      flush_pending_blanks()
      saw_custom_start = 1
      in_custom = 1
      print
      next
    }
    !in_fence && marker == custom_end {
      if (!inserted && saw_custom_start) {
        print ""
        print_block()
        print ""
        inserted = 1
      }
      in_custom = 0
      print
      next
    }
    has_custom && !in_custom && !in_fence && ($0 == "" || $0 == "\r") {
      pending_blank_count += 1
      next
    }
    { flush_pending_blanks(); print }
    END {
      if (!inserted) {
        flush_pending_blanks()
        if (NR > 0) print ""
        print_block()
      } else {
        flush_pending_blanks()
      }
    }
  ' "$agents_target" > "$tmp"

  cp "$tmp" "$agents_target"
  rm -f "$block_file" "$tmp"
  info "managed AGENTS.md block installed/refreshed at ${agents_file#$repo_root/}"
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
main() {
  local command="${1:-}"
  shift || true
  case "$command" in
    doctor)             cmd_doctor "$@" ;;
    new)                cmd_new "$@" ;;
    verify)             cmd_verify "$@" ;;
    verify-lifecycle)   cmd_verify_lifecycle "$@" ;;
    verify-staging)     cmd_verify_staging "$@" ;;
    re-adjudication)    cmd_re_adjudication "$@" ;;
    record-fallback-receipt) cmd_record_fallback_receipt "$@" ;;
    rebind-artifact)    cmd_rebind_artifact "$@" ;;
    repair-redispatch)  cmd_repair_redispatch "$@" ;;
    post-merge)         cmd_post_merge "$@" ;;
    review-chain)       cmd_review_chain "$@" ;;
    verify-live-docs)   cmd_verify_live_docs "$@" ;;
    verify-authoring-constraints) cmd_fw_script verify-authoring-constraints.py "$@" ;;
    verify-post-d6-scope) cmd_fw_script verify-post-d6-scope.sh "$@" ;;
    verify-handoff-base) cmd_fw_script verify-handoff-base.sh "$@" ;;
    strict-p3-commands) cmd_strict_p3_commands "$@" ;;
    goal-card)          cmd_fw_script emit-goal-card.py "$@" ;;
    review-seats)       cmd_fw_script review-seats.sh "$@" ;;
    gate-preflight)     cmd_gate_preflight "$@" ;;
    lint-artifact)      cmd_fw_script verify-dispatch-shape.sh "$@" ;;
    append-supplemental-review) cmd_fw_script append-supplemental-review.sh "$@" ;;
    capability)         cmd_capability "$@" ;;
    generate-overlays)  cmd_generate_overlays "$@" ;;
    update)             cmd_update "$@" ;;
    agents)             cmd_agents_install "$@" ;;
    -h|--help|"")       usage ;;
    *)                  die "unknown command: $command" ;;
  esac
}

main "$@"
