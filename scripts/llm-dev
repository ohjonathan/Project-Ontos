#!/usr/bin/env bash
# llm-dev — repo-local adopter wrapper for llm-dev-framework (v1.5.0+).
#
# This script is copied verbatim into adopter repos at scripts/llm-dev
# by `scripts/install-adopter.sh`. It resolves the framework checkout
# from .llm-dev/config.yaml so agents never need a hard-wired absolute
# framework path.
#
# Commands:
#   doctor                                 — environment + config health check
#   new <deliverable-id>                   — scaffold manifest + tracker
#   verify <manifest-path>                 — run framework verify-adopter.sh
#                                            (manifest conformance only;
#                                            does NOT prove lifecycle
#                                            execution or reviewer dispatch)
#   verify-lifecycle <manifest-path>       — run framework verify-lifecycle.sh
#                                            in --mode strict-p3 by default;
#                                            v1.8.0+ accepts --mode
#                                            provider-limited-fallback for
#                                            honest fallback verification
#                                            (issue #5 + issue #10)
#   re-adjudication list|verify <manifest> — v1.8.0+ inspect or validate
#                                            the manifest's
#                                            re_adjudication_queue[]
#                                            (issue #10)
#   rebind-artifact --result ...           — validate and rebind a dispatch
#                                            result row to a moved artifact
#   post-merge --pr ... --branch ...       — reconcile/report PR branch
#                                            reachability after merge
#   review-chain report <manifest>         — non-gating review-chain depth
#                                            report
#   verify-live-docs [--policy <path>]     — stale live-doc phrase sweep
#   strict-p3-commands <manifest-path>      — v1.9.0+ emit canonical final
#                                            verification commands for a
#                                            strict-P3 lifecycle
#   generate-overlays --target ... --out ... — emit non-evidence runtime
#                                            overlay packages for skills,
#                                            plugins, and extensions
#                                            (codex|claude|gemini|agy|all)
#   update --to latest|vX.Y.Z|<ref>        — re-pin framework checkout
#   agents install                         — insert/refresh AGENTS.md block
#
# Environment overrides:
#   LLM_DEV_CONFIG  — path to config (default: <repo-root>/.llm-dev/config.yaml)

set -euo pipefail

START_MARKER="<!-- llm-dev-framework:start -->"
END_MARKER="<!-- llm-dev-framework:end -->"
CUSTOM_START_MARKER="<!-- USER CUSTOM -->"
CUSTOM_END_MARKER="<!-- /USER CUSTOM -->"

usage() {
  cat <<'USAGE'
usage:
  scripts/llm-dev doctor
  scripts/llm-dev new <deliverable-id>
  scripts/llm-dev verify <manifest-path>
  scripts/llm-dev verify-lifecycle [--mode strict-p3|provider-limited-fallback]
                                    [--allow-warn] [--explain-recovery]
                                    <manifest-path>
  scripts/llm-dev verify-staging [--manifest <path>] [--expect <p>] ...
                                  [--forbid <p>] ... [--summary-untracked]
  scripts/llm-dev re-adjudication <list|verify> <manifest-path>
  scripts/llm-dev rebind-artifact --result <path> --dispatch-id <id>
                                  --artifact <path> --reason <text>
  scripts/llm-dev post-merge --pr <number> --branch <branch> [--verify-all]
  scripts/llm-dev review-chain report <manifest-path>
  scripts/llm-dev verify-live-docs [--policy <path>]
  scripts/llm-dev strict-p3-commands <manifest-path>
  scripts/llm-dev generate-overlays --target codex|claude|gemini|agy|all
                                    --out <dir> [--force]
                                    [--agy-import-manifest <path>]
  scripts/llm-dev update --to latest|vX.Y.Z|<ref>
  scripts/llm-dev agents install
  scripts/llm-dev --help

Note:
  `verify`            — manifest conformance only (does not prove
                        lifecycle execution or reviewer dispatch).
  `verify-lifecycle`  — strict-P3 lifecycle receipt verification (the
                        gate that proves real multi-family review +
                        verifier dispatch happened — see issue #5).
                        v1.8.0+ accepts --mode provider-limited-fallback
                        for honest fallback verification (issue #10).
  `verify-staging`    — (v1.7.1+) inspects git index + working tree +
                        framework-submodule state against expected /
                        forbidden paths BEFORE commit and before D.6
                        final approval.
  `re-adjudication`   — (v1.8.0+) inspect or validate the manifest's
                        re_adjudication_queue[] (issue #10).
  `rebind-artifact`   — validate a moved review artifact and update the
                        matching dispatch-result row with its new path/hash.
  `post-merge`        — fetch origin/main, fast-forward local main when
                        safe, check branch reachability, and run default
                        post-merge validations.
  `review-chain`      — non-gating review family/round depth report.
  `verify-live-docs`  — stale live-doc phrase sweep with version-aware
                        historical allowlists; extend with --policy,
                        docs/live-docs-policy.yaml, or
                        .llm-dev/live-docs-policy.yaml.
  `strict-p3-commands` — (v1.9.0+) print canonical verifier command
                        blocks derived from the manifest, so handoffs
                        do not drift on argument shape (issue #11).
  `generate-overlays` — emit generated, non-evidence skills/plugins/
                        extensions. Rendered prompts and lifecycle
                        receipts remain the only strict-P3 evidence path.

Environment:
  LLM_DEV_CONFIG  Override config path (default: .llm-dev/config.yaml under repo root)
USAGE
}

die() {
  echo "llm-dev: $*" >&2
  exit 1
}

info() {
  echo "llm-dev: $*"
}

find_repo_root() {
  local script_dir script_root cwd_root
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  script_root="$(cd "$script_dir/.." && pwd)"

  # Prefer the repo that owns this copied wrapper. This keeps absolute
  # invocations like `/path/to/repo/scripts/llm-dev doctor` from accidentally
  # binding to the caller's current git repo.
  if [[ -r "$script_root/.llm-dev/config.yaml" ]]; then
    printf '%s\n' "$script_root"
    return
  fi

  if cwd_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    # The same-inode check keeps install-time calls rooted in the wrapper's
    # own repo even before .llm-dev/config.yaml exists.
    if [[ -r "$cwd_root/.llm-dev/config.yaml" || "$cwd_root" -ef "$script_root" ]]; then
      printf '%s\n' "$cwd_root"
      return
    fi
  fi

  printf '%s\n' "$script_root"
}

repo_root="$(find_repo_root)"
config_path="${LLM_DEV_CONFIG:-$repo_root/.llm-dev/config.yaml}"

# Trim a config value: strip inline `# comment`, leading/trailing
# whitespace, and surrounding quotes.
trim_value() {
  sed -E \
    -e 's/[[:space:]]+#.*$//' \
    -e 's/^[[:space:]]+//' \
    -e 's/[[:space:]]+$//' \
    -e 's/^"//' \
    -e 's/"$//' \
    -e "s/^'//" \
    -e "s/'$//"
}

config_get() {
  local key="$1"
  [[ -r "$config_path" ]] || return 1
  sed -n -E "s/^[[:space:]]*${key}:[[:space:]]*//p" "$config_path" \
    | head -n 1 \
    | trim_value
}

config_required() {
  local key="$1" value
  value="$(config_get "$key" || true)"
  [[ -n "$value" ]] || die "missing required config key '$key' in $config_path"
  printf '%s\n' "$value"
}

abs_path() {
  local p="$1"
  case "$p" in
    /*) printf '%s\n' "$p" ;;
    *)  printf '%s/%s\n' "$repo_root" "$p" ;;
  esac
}

framework_path() {
  abs_path "$(config_required framework_path)"
}

framework_path_or_self() {
  if [[ -r "$config_path" ]]; then
    framework_path
  else
    printf '%s\n' "$repo_root"
  fi
}

manifest_dir() {
  config_get manifest_dir || true
}

# Rewrite a single top-level scalar key in config.yaml. Adds the key
# at the end of the file if it does not already exist.
set_config_value() {
  local key="$1" value="$2" tmp
  [[ -r "$config_path" ]] || die "config not readable at $config_path"
  tmp="$(mktemp)"
  awk -v key="$key" -v value="$value" '
    BEGIN { done = 0 }
    $0 ~ "^[[:space:]]*" key ":" {
      print key ": " value
      done = 1
      next
    }
    { print }
    END {
      if (!done) { print key ": " value }
    }
  ' "$config_path" > "$tmp"
  mv "$tmp" "$config_path"
}

resolve_latest_tag() {
  local repo_url="$1" tags
  command -v python3 >/dev/null 2>&1 || die "python3 is required for update --to latest"
  tags="$(git -c protocol.file.allow=always ls-remote --tags --refs "$repo_url" 'v[0-9]*.[0-9]*.[0-9]*' \
            | awk '{print $2}' \
            | sed 's#refs/tags/##')"
  [[ -n "$tags" ]] || die "no semver tags found at $repo_url"
  printf '%s\n' "$tags" | python3 -c '
import re, sys
def key(t):
    m = re.fullmatch(r"v([0-9]+)\.([0-9]+)\.([0-9]+)", t)
    return tuple(int(p) for p in m.groups()) if m else (-1, -1, -1)
tags = [l.strip() for l in sys.stdin if l.strip()]
print(sorted(tags, key=key)[-1])
'
}

checkout_framework_ref() {
  local fw="$1" ref="$2"
  git -C "$fw" fetch --tags --force origin >/dev/null 2>&1 || true
  if git -C "$fw" rev-parse -q --verify "refs/tags/$ref^{commit}" >/dev/null; then
    git -C "$fw" checkout --detach "$ref" >/dev/null
  elif git -C "$fw" rev-parse -q --verify "refs/remotes/origin/$ref^{commit}" >/dev/null; then
    git -C "$fw" checkout --detach "origin/$ref" >/dev/null
  else
    git -C "$fw" checkout --detach "$ref" >/dev/null
  fi
}

wrapper_drift_status() {
  local fw="$1"
  local wrapper="$repo_root/scripts/llm-dev"
  local framework_wrapper="$fw/scripts/llm-dev"
  if [[ ! -r "$framework_wrapper" ]]; then
    printf 'missing-framework-wrapper:%s\n' "$framework_wrapper"
    return
  fi
  if [[ ! -r "$wrapper" ]]; then
    printf 'missing-adopter-wrapper:%s\n' "$wrapper"
    return
  fi
  if cmp -s "$framework_wrapper" "$wrapper"; then
    printf 'ok\n'
  else
    printf 'drift:%s:%s\n' "$wrapper" "$framework_wrapper"
  fi
}

refresh_adopter_wrapper() {
  local fw="$1"
  local wrapper="$repo_root/scripts/llm-dev"
  local framework_wrapper="$fw/scripts/llm-dev"
  [[ -r "$framework_wrapper" ]] || die "framework wrapper missing at $framework_wrapper"
  mkdir -p "$repo_root/scripts"
  cp "$framework_wrapper" "$wrapper"
  chmod +x "$wrapper"
}

# ---------------------------------------------------------------------------
# doctor
# ---------------------------------------------------------------------------
cmd_doctor() {
  local failed=0
  local fw fw_rel ref repo_url

  [[ -r "$config_path" ]] || die "config not found at $config_path (run install-adopter.sh first)"
  fw="$(framework_path)"
  fw_rel="$(config_required framework_path)"
  ref="$(config_get framework_ref || true)"
  repo_url="$(config_get framework_repo_url || true)"

  echo "llm-dev doctor"
  echo "  repo:               $repo_root"
  echo "  config:             ${config_path#$repo_root/}"
  echo "  framework_path:     $fw_rel"
  [[ -n "$ref" ]]      && echo "  framework_ref:      $ref"
  [[ -n "$repo_url" ]] && echo "  framework_repo_url: $repo_url"

  check_cmd() {
    if command -v "$1" >/dev/null 2>&1; then
      echo "  PASS command: $1"
    else
      echo "  FAIL command: $1" >&2
      failed=1
    fi
  }

  check_cmd git
  check_cmd bash
  check_cmd python3
  check_cmd check-jsonschema

  if [[ -d "$fw" && ( -d "$fw/.git" || -f "$fw/.git" || -f "$fw/scripts/verify-adopter.sh" ) ]]; then
    echo "  PASS framework checkout: $fw_rel"
  else
    echo "  FAIL framework checkout missing: $fw_rel" >&2
    failed=1
  fi

  if [[ -x "$fw/scripts/verify-adopter.sh" && -x "$fw/examples/day-one.sh" ]]; then
    echo "  PASS framework scripts (verify-adopter.sh, day-one.sh)"
  else
    echo "  FAIL framework scripts missing or not executable" >&2
    failed=1
  fi

  case "$(wrapper_drift_status "$fw")" in
    ok)
      echo "  PASS adopter wrapper: scripts/llm-dev matches framework copy"
      ;;
    missing-adopter-wrapper:*)
      echo "  FAIL adopter wrapper missing: scripts/llm-dev" >&2
      echo "       run: bash $fw/scripts/install-adopter.sh <repo>  # or scripts/llm-dev update --to ${ref:-latest}" >&2
      failed=1
      ;;
    missing-framework-wrapper:*)
      echo "  FAIL framework wrapper missing: $fw/scripts/llm-dev" >&2
      failed=1
      ;;
    drift:*)
      echo "  FAIL adopter wrapper drift: scripts/llm-dev differs from $fw/scripts/llm-dev" >&2
      echo "       run: scripts/llm-dev update --to ${ref:-latest}" >&2
      failed=1
      ;;
  esac

  for cli in claude codex gemini; do
    if command -v "$cli" >/dev/null 2>&1; then
      echo "  PASS worker CLI: $cli"
    else
      echo "  WARN worker CLI not installed: $cli (review-board phases will need a host with it)"
    fi
  done

  if [[ "$failed" -eq 0 ]]; then
    echo "llm-dev doctor: PASS"
  else
    die "doctor failed"
  fi
}

# ---------------------------------------------------------------------------
# new <deliverable-id>
# ---------------------------------------------------------------------------
cmd_new() {
  local deliverable_id="${1:-}" fw mdir
  [[ -n "$deliverable_id" ]] || die "new requires <deliverable-id>"
  fw="$(framework_path)"
  mdir="$(manifest_dir)"
  [[ -n "$mdir" ]] || mdir="manifests"

  (
    cd "$repo_root"
    MANIFEST_DIR="$(abs_path "$mdir")" bash "$fw/examples/day-one.sh" "$deliverable_id"
  )
}

# ---------------------------------------------------------------------------
# verify <manifest-path>
# ---------------------------------------------------------------------------
cmd_verify() {
  local manifest="${1:-}" fw
  [[ -n "$manifest" ]] || die "verify requires <manifest-path>"
  fw="$(framework_path)"
  bash "$fw/scripts/verify-adopter.sh" "$(abs_path "$manifest")"
}

# ---------------------------------------------------------------------------
# verify-lifecycle <manifest-path> — issue #5 strict-P3 receipt verifier.
#
# Delegates to scripts/verify-lifecycle.sh in --mode strict-p3. Unlike
# `verify`, this command requires the deliverable's lifecycle receipt
# inventory to exist and prove that real multi-family review + verifier
# dispatch happened — D.6 cannot self-attest closure without it.
# ---------------------------------------------------------------------------
cmd_verify_lifecycle() {
  local manifest="" fw allow_warn=0 explain_recovery=0 mode="strict-p3"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --allow-warn) allow_warn=1 ;;
      --mode)
        shift
        mode="${1:-}"
        [[ -n "$mode" ]] || die "verify-lifecycle: missing value after --mode"
        ;;
      --explain-recovery)
        # F35/F36/F37 (v1.7.0, Issue #17): diagnostic flag — classifies
        # each strict-P3 failure into one of eight recovery classes
        # (v1.7.0) or one of thirteen (v1.8.0, Issue #10) and prints
        # the next action. Diagnostic only; no file mutation.
        explain_recovery=1
        ;;
      -h|--help)
        cat <<'USAGE'
usage: scripts/llm-dev verify-lifecycle [--mode strict-p3|provider-limited-fallback]
                                         [--allow-warn]
                                         [--explain-recovery]
                                         <manifest-path>

Run scripts/verify-lifecycle.sh against <manifest-path>. Default mode
is strict-p3. v1.8.0 (Issue #10) adds --mode provider-limited-fallback
for honest fallback verification (mutually exclusive with --allow-warn).

With --explain-recovery, each failure is tagged with a recovery class
(v1.7.0: missing-receipt,
 failed-dispatch-raw-verdict-candidate-available,
 receipt-present-artifact-frontmatter-invalid,
 stderr-throttle-valid-artifact, artifact-summary-stub,
 true-no-evidence, dispatch-attestation-failed,
 parallelism-attestation-missing; v1.8.0 adds
 blocked-family-evidence-missing, fallback-receipt-missing,
 re-adjudication-missing, mechanical-stub-only,
 provider-limited-fallback-incomplete) and a next-action hint.
USAGE
        exit 0
        ;;
      --*)
        die "verify-lifecycle: unknown flag: $1"
        ;;
      *)
        if [[ -z "$manifest" ]]; then
          manifest="$1"
        else
          die "verify-lifecycle: unexpected positional arg: $1"
        fi
        ;;
    esac
    shift || true
  done
  [[ -n "$manifest" ]] || die "verify-lifecycle requires <manifest-path>"
  case "$mode" in
    strict-p3|provider-limited-fallback) ;;
    *) die "verify-lifecycle: unknown --mode $mode (use strict-p3 or provider-limited-fallback)" ;;
  esac
  if [[ "$mode" == "provider-limited-fallback" && "$allow_warn" == "1" ]]; then
    die "verify-lifecycle: --allow-warn is incompatible with --mode provider-limited-fallback"
  fi
  fw="$(framework_path)"
  local args=("$(abs_path "$manifest")" --mode "$mode")
  [[ "$allow_warn" == "1" ]] && args+=(--allow-warn)
  [[ "$explain_recovery" == "1" ]] && args+=(--explain-recovery)
  bash "$fw/scripts/verify-lifecycle.sh" "${args[@]}"
}

# ---------------------------------------------------------------------------
# re-adjudication list|verify <manifest> — v1.8.0 (Issue #10).
#
# Wraps scripts/verify-re-adjudication.sh and provides a friendly
# "list" subcommand that pretty-prints queue items as a table for
# operator triage. Pre-v1.8.0 manifests with no queue block exit
# cleanly.
# ---------------------------------------------------------------------------
cmd_re_adjudication() {
  local sub="" manifest="" fw
  if [[ $# -lt 1 ]]; then
    cat <<'USAGE' >&2
usage: scripts/llm-dev re-adjudication <list|verify> <manifest-path>

  list   — pretty-print manifest.re_adjudication_queue[] entries.
  verify — run scripts/verify-re-adjudication.sh against the manifest.

Pre-v1.8.0 manifests with no queue block exit 0 trivially.
USAGE
    exit 64
  fi
  sub="$1"; shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        echo "usage: scripts/llm-dev re-adjudication <list|verify> <manifest-path>"
        exit 0
        ;;
      --*)
        die "re-adjudication: unknown flag: $1"
        ;;
      *)
        if [[ -z "$manifest" ]]; then
          manifest="$1"
        else
          die "re-adjudication: unexpected positional arg: $1"
        fi
        ;;
    esac
    shift || true
  done
  [[ -n "$manifest" ]] || die "re-adjudication: requires <manifest-path>"
  fw="$(framework_path)"
  case "$sub" in
    verify)
      bash "$fw/scripts/verify-re-adjudication.sh" "$(abs_path "$manifest")"
      ;;
    list)
      python3 - "$(abs_path "$manifest")" <<'PY'
import sys
import yaml

manifest_path = sys.argv[1]
try:
    with open(manifest_path) as f:
        m = yaml.safe_load(f) or {}
except (OSError, yaml.YAMLError) as e:
    print(f"re-adjudication: cannot read manifest: {e}", file=sys.stderr)
    sys.exit(1)

queue = m.get("re_adjudication_queue") or []
if not isinstance(queue, list) or not queue:
    print("re-adjudication: queue is empty or absent")
    sys.exit(0)

headers = ("id", "status", "priority", "blocked_family_ref", "owner", "rerun_trigger")
widths = {h: len(h) for h in headers}
rows = []
for item in queue:
    if not isinstance(item, dict):
        continue
    row = {h: str(item.get(h, "")) for h in headers}
    rows.append(row)
    for h in headers:
        widths[h] = max(widths[h], len(row[h]))

def fmt(row):
    return "  ".join(row[h].ljust(widths[h]) for h in headers)

print(fmt({h: h for h in headers}))
print(fmt({h: "-" * widths[h] for h in headers}))
for row in rows:
    print(fmt(row))

print(f"\nre-adjudication: {len(rows)} item(s)")
PY
      ;;
    *)
      die "re-adjudication: unknown subcommand '$sub' (use list or verify)"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# rebind-artifact --result <path> --dispatch-id <id> --artifact <path> --reason <text>
# ---------------------------------------------------------------------------
cmd_rebind_artifact() {
  local result="" dispatch_id="" artifact="" reason=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --result) shift; result="${1:-}" ;;
      --dispatch-id) shift; dispatch_id="${1:-}" ;;
      --artifact) shift; artifact="${1:-}" ;;
      --reason) shift; reason="${1:-}" ;;
      -h|--help)
        echo "usage: scripts/llm-dev rebind-artifact --result <path> --dispatch-id <id> --artifact <path> --reason <text>"
        exit 0
        ;;
      *) die "rebind-artifact: unknown argument: $1" ;;
    esac
    shift || true
  done
  [[ -n "$result" && -n "$dispatch_id" && -n "$artifact" && -n "$reason" ]] \
    || die "rebind-artifact requires --result, --dispatch-id, --artifact, and --reason"
  local fw
  fw="$(framework_path_or_self)"
  python3 - "$repo_root" "$fw" "$(abs_path "$result")" "$dispatch_id" "$(abs_path "$artifact")" "$reason" <<'PY'
import datetime as dt
import hashlib
import sys
import tempfile
from pathlib import Path

import yaml

repo = Path(sys.argv[1]).resolve()
framework = Path(sys.argv[2]).resolve()
sys.path.insert(0, str(framework / "scripts" / "_lib"))
from verdict_shape import classify_verdict_shape  # noqa: E402

result_path = Path(sys.argv[3]).resolve()
dispatch_id = sys.argv[4]
artifact_path = Path(sys.argv[5]).resolve()
reason = sys.argv[6].strip()

if not result_path.is_file():
    raise SystemExit(f"rebind-artifact: result file not found: {result_path}")
if not artifact_path.is_file():
    raise SystemExit(f"rebind-artifact: artifact file not found: {artifact_path}")
try:
    rel_artifact = artifact_path.relative_to(repo)
except ValueError:
    raise SystemExit("rebind-artifact: artifact must live under the adopter root")
try:
    result_path.relative_to(repo)
except ValueError:
    raise SystemExit("rebind-artifact: result file must live under the adopter root")

data = yaml.safe_load(result_path.read_text()) or {}
rows = data.get("results") or []
if not isinstance(rows, list):
    raise SystemExit("rebind-artifact: result YAML has no results[] list")
matches = [row for row in rows if isinstance(row, dict) and row.get("dispatch_id") == dispatch_id]
if len(matches) != 1:
    raise SystemExit(f"rebind-artifact: expected exactly one dispatch_id={dispatch_id!r}, found {len(matches)}")

h = hashlib.sha256()
with artifact_path.open("rb") as fh:
    for chunk in iter(lambda: fh.read(65536), b""):
        h.update(chunk)
row = matches[0]
shape = classify_verdict_shape(artifact_path.read_text(encoding="utf-8", errors="replace"))
if shape.get("shape") != "verdict_shaped":
    missing = "; ".join(str(x) for x in shape.get("missing") or [])
    raise SystemExit(f"rebind-artifact: artifact is not verdict-shaped; refusing status repair ({missing})")

old_status = row.get("status")
row["artifact_path"] = str(rel_artifact)
row["artifact_sha256"] = h.hexdigest()
if old_status != "completed":
    row["status_before_rebind"] = old_status
row["status"] = "completed"
row["artifact_rebind_reason"] = reason
row["artifact_rebound_at"] = dt.datetime.now(dt.timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")

with tempfile.NamedTemporaryFile("w", delete=False, dir=str(result_path.parent)) as tmp:
    yaml.safe_dump(data, tmp, sort_keys=False)
    tmp_path = Path(tmp.name)
tmp_path.replace(result_path)
print(
    f"rebind-artifact: updated {result_path.relative_to(repo)} dispatch_id={dispatch_id} "
    f"artifact_path={rel_artifact} status={old_status!r}->'completed'"
)
PY
}

# ---------------------------------------------------------------------------
# post-merge --pr <number> --branch <branch> [--verify-all]
# ---------------------------------------------------------------------------
cmd_post_merge() {
  local pr="" branch="" verify_all=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pr) shift; pr="${1:-}" ;;
      --branch) shift; branch="${1:-}" ;;
      --verify-all) verify_all=1 ;;
      -h|--help)
        echo "usage: scripts/llm-dev post-merge --pr <number> --branch <branch> [--verify-all]"
        exit 0
        ;;
      *) die "post-merge: unknown argument: $1" ;;
    esac
    shift || true
  done
  [[ -n "$pr" && -n "$branch" ]] || die "post-merge requires --pr and --branch"
  local post_merge_fail=0
  echo "llm-dev post-merge report"
  echo "  repo:   $repo_root"
  echo "  pr:     #$pr"
  echo "  branch: $branch"
  git -C "$repo_root" rev-parse --short HEAD | sed 's/^/  head:   /'

  echo "  fetch:  origin main"
  if ! git -C "$repo_root" fetch origin main >/dev/null 2>&1; then
    echo "  fetch:  FAILED (origin/main unavailable)"
    post_merge_fail=1
  fi

  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
    echo "  local branch: present"
  else
    echo "  local branch: absent"
  fi
  if git -C "$repo_root" ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1; then
    echo "  remote branch: origin/$branch present"
  else
    echo "  remote branch: origin/$branch absent or origin unavailable"
  fi
  local github_state="" github_merge_commit="" github_head="" github_base="" github_merged_at=""
  if command -v gh >/dev/null 2>&1; then
    local github_meta="" github_summary=""
    github_meta="$(gh pr view "$pr" --json state,mergedAt,mergeCommit,headRefName,baseRefName 2>/dev/null || true)"
    if [[ -n "$github_meta" ]]; then
      github_summary="$(python3 - "$github_meta" <<'PY'
import json
import sys

doc = json.loads(sys.argv[1])
merge_commit = doc.get("mergeCommit") or {}
print("|".join([
    str(doc.get("state") or ""),
    str(merge_commit.get("oid") or ""),
    str(doc.get("headRefName") or ""),
    str(doc.get("baseRefName") or ""),
    str(doc.get("mergedAt") or ""),
]))
PY
)"
      IFS='|' read -r github_state github_merge_commit github_head github_base github_merged_at <<<"$github_summary"
      echo "  github: $github_state head=$github_head base=$github_base mergedAt=$github_merged_at mergeCommit=$github_merge_commit"
    else
      echo "  github: gh could not read PR #$pr"
    fi
  else
    echo "  github: gh not installed; skipped PR metadata"
  fi

  if git -C "$repo_root" show-ref --verify --quiet refs/remotes/origin/main; then
    if git -C "$repo_root" show-ref --verify --quiet refs/heads/main; then
      if git -C "$repo_root" merge-base --is-ancestor main refs/remotes/origin/main; then
        if [[ "$(git -C "$repo_root" branch --show-current)" == "main" ]]; then
          if git -C "$repo_root" merge --ff-only refs/remotes/origin/main >/dev/null; then
            echo "  local main: fast-forwarded to origin/main"
          else
            echo "  local main: fast-forward FAILED"
            post_merge_fail=1
          fi
        else
          if git -C "$repo_root" branch -f main refs/remotes/origin/main >/dev/null; then
            echo "  local main: fast-forwarded to origin/main"
          else
            echo "  local main: fast-forward FAILED"
            post_merge_fail=1
          fi
        fi
      else
        echo "  local main: diverged from origin/main; refusing non-ff update"
        post_merge_fail=1
      fi
    else
      if git -C "$repo_root" branch main refs/remotes/origin/main >/dev/null; then
        echo "  local main: created at origin/main"
      else
        echo "  local main: create FAILED"
        post_merge_fail=1
      fi
    fi
  fi

  local branch_ref=""
  if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$branch"; then
    branch_ref="$branch"
  elif git -C "$repo_root" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    branch_ref="refs/remotes/origin/$branch"
  fi
  if git -C "$repo_root" show-ref --verify --quiet refs/heads/main; then
    if [[ -n "$branch_ref" ]] && git -C "$repo_root" merge-base --is-ancestor "$branch_ref" main; then
      echo "  reachability: $branch is contained in local main"
    elif [[ "$github_state" == "MERGED" && -n "$github_merge_commit" ]] \
      && git -C "$repo_root" cat-file -e "$github_merge_commit^{commit}" 2>/dev/null \
      && git -C "$repo_root" merge-base --is-ancestor "$github_merge_commit" main; then
      echo "  reachability: PR merge commit ${github_merge_commit:0:12} is contained in local main (squash/rebase merge accepted)"
    else
      echo "  reachability: $branch is NOT contained in local main"
      post_merge_fail=1
    fi
  else
    echo "  reachability: skipped (local main missing)"
    post_merge_fail=1
  fi

  local fw
  fw="$(framework_path_or_self)"
  echo "  validation: git diff --check"
  git -C "$repo_root" diff --check || post_merge_fail=1
  echo "  validation: verify-schema.sh"
  bash "$fw/scripts/verify-schema.sh" || post_merge_fail=1
  echo "  validation: verify-frontmatter.sh"
  bash "$fw/scripts/verify-frontmatter.sh" || post_merge_fail=1

  echo "  destructive actions: none (fast-forward only)"
  if [[ "$verify_all" -eq 1 ]]; then
    echo "  verify-all: running $fw/scripts/verify-all.sh"
    bash "$fw/scripts/verify-all.sh" || post_merge_fail=1
  fi
  return "$post_merge_fail"
}

# ---------------------------------------------------------------------------
# review-chain report <manifest>
# ---------------------------------------------------------------------------
cmd_review_chain() {
  local sub="${1:-}" manifest="${2:-}"
  [[ "$sub" == "report" && -n "$manifest" ]] || die "usage: scripts/llm-dev review-chain report <manifest-path>"
  python3 - "$repo_root" "$(abs_path "$manifest")" <<'PY'
import sys
from pathlib import Path

import yaml

repo = Path(sys.argv[1]).resolve()
manifest_path = Path(sys.argv[2]).resolve()
manifest = yaml.safe_load(manifest_path.read_text()) or {}
inventory_ref = manifest.get("lifecycle_receipt_inventory_path")
if not inventory_ref:
    print("review-chain: no lifecycle_receipt_inventory_path in manifest")
    raise SystemExit(0)
candidate = Path(inventory_ref)
if not candidate.is_absolute():
    for base in (manifest_path.parent, repo):
        maybe = (base / candidate).resolve()
        if maybe.is_file():
            candidate = maybe
            break
inventory = yaml.safe_load(Path(candidate).read_text()) or {}
rows = inventory.get("receipts") or []
groups = {}
for row in rows:
    if not isinstance(row, dict):
        continue
    key = (row.get("phase") or "", row.get("role") or "")
    groups.setdefault(key, []).append(row)
print(f"review-chain report: {manifest_path.relative_to(repo) if manifest_path.is_relative_to(repo) else manifest_path}")
print(f"inventory: {Path(candidate).relative_to(repo) if Path(candidate).is_relative_to(repo) else candidate}")
for (phase, role), items in sorted(groups.items()):
    families = sorted({str(i.get("family") or "") for i in items if i.get("family")})
    rounds = sorted({int(i.get("round") or 1) for i in items})
    providers = sorted({str(i.get("provider") or "") for i in items if i.get("provider")})
    fallback = sum(1 for i in items if i.get("provider_limited_fallback") or i.get("operator_judged"))
    print(
        f"- {phase or '<none>'} / {role or '<none>'}: "
        f"receipts={len(items)} families={len(families)} providers={len(providers)} "
        f"rounds={','.join(map(str, rounds)) or '-'} fallback={fallback}"
    )
    print(f"  families: {', '.join(families) if families else '-'}")
print("review-chain: report only; no gate decision made")
PY
}

# ---------------------------------------------------------------------------
# verify-live-docs
# ---------------------------------------------------------------------------
cmd_verify_live_docs() {
  local policy=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --policy) shift; policy="${1:-}" ;;
      -h|--help)
        echo "usage: scripts/llm-dev verify-live-docs [--policy <path>]"
        exit 0
        ;;
      *) die "verify-live-docs: unknown argument: $1" ;;
    esac
    shift || true
  done
  python3 - "$repo_root" "${policy:+$(abs_path "$policy")}" <<'PY'
import sys
import re
from pathlib import Path

import yaml

repo = Path(sys.argv[1]).resolve()
explicit_policy = Path(sys.argv[2]).resolve() if len(sys.argv) > 2 and sys.argv[2] else None
if explicit_policy and not explicit_policy.is_file():
    raise SystemExit(f"verify-live-docs: policy file not found: {explicit_policy}")
roots = [
    repo / "CHANGELOG.md",
    repo / "ROADMAP.md",
    repo / "framework.md",
    repo / "playbook.md",
    repo / "tokens.md",
    repo / "templates",
    repo / "docs",
]
policy = {
    "current_version": "1.10.1",
    "excluded_prefixes": [
        "docs/logs",
        "docs/handoffs",
        "docs/retros",
        "docs/trackers",
    ],
    "patterns": [
        {"id": "stale-v1.9.7", "text": "v1.9.7"},
        {"id": "agy-argv-prompt-body", "text": "agy --sandbox --print --print-timeout <duration> <prompt-body>"},
        {"id": "stdin-codex-only", "text": "codex only; else null"},
    ],
    "historical_allow": [
        {
            "id": "stale-v1.9.7",
            "path": "docs/v1.10.0-antigravity-cli-migration-proposal.md",
            "max_target_release": "1.10.0",
        },
        {
            "id": "stale-v1.9.7",
            "path": "docs/specs/v1.9.6-self-receipting-dogfood-readjudication-spec.md",
            "max_target_release": "1.9.6",
        },
    ],
}

def merge_policy_file(path):
    if not path or not path.is_file():
        return
    doc = yaml.safe_load(path.read_text()) or {}
    if not isinstance(doc, dict):
        raise SystemExit(f"verify-live-docs: policy must be a mapping: {path}")
    if doc.get("current_version"):
        policy["current_version"] = str(doc["current_version"])
    for key in ("excluded_prefixes", "patterns", "historical_allow"):
        if key in doc:
            if not isinstance(doc[key], list):
                raise SystemExit(f"verify-live-docs: policy.{key} must be a list: {path}")
            policy[key].extend(doc[key])

for policy_path in (
    repo / "docs" / "live-docs-policy.yaml",
    repo / ".llm-dev" / "live-docs-policy.yaml",
    explicit_policy,
):
    merge_policy_file(policy_path)

def version_tuple(value):
    text = str(value or "").strip()
    text = text[1:] if text.startswith("v") else text
    nums = [int(x) for x in re.findall(r"\d+", text)[:3]]
    while len(nums) < 3:
        nums.append(0)
    return tuple(nums)

def frontmatter_target_release(text):
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return ""
    for line in lines[1:80]:
        if line.strip() == "---":
            break
        if line.startswith("target_release:"):
            return line.split(":", 1)[1].strip().strip('"').strip("'")
    return ""

def is_excluded(rel):
    rel_s = rel.as_posix()
    for prefix in policy["excluded_prefixes"]:
        prefix_s = str(prefix).strip().strip("/")
        if rel_s == prefix_s or rel_s.startswith(prefix_s + "/"):
            return True
    return False

def is_allowed(pattern_id, rel, target_release):
    rel_s = rel.as_posix()
    target_v = version_tuple(target_release)
    current_v = version_tuple(policy["current_version"])
    for entry in policy["historical_allow"]:
        if not isinstance(entry, dict):
            continue
        if entry.get("id") not in (None, pattern_id):
            continue
        if str(entry.get("path") or "").strip().strip("/") != rel_s:
            continue
        max_release = entry.get("max_target_release")
        if max_release and target_v > version_tuple(max_release):
            continue
        min_release = entry.get("min_target_release")
        if min_release and target_v < version_tuple(min_release):
            continue
        expires_after = entry.get("expires_after_current_version")
        if expires_after and current_v > version_tuple(expires_after):
            continue
        return True
    return False

patterns = []
for item in policy["patterns"]:
    if not isinstance(item, dict) or not item.get("id") or not item.get("text"):
        raise SystemExit("verify-live-docs: each policy pattern must include id and text")
    patterns.append((str(item["id"]), str(item["text"])))

files = []
for root in roots:
    if root.is_file():
        files.append(root)
    elif root.is_dir():
        files.extend(p for p in root.rglob("*.md") if p.is_file())

hits = []
for path in sorted(set(files)):
    rel = path.relative_to(repo)
    if is_excluded(rel):
        continue
    text = path.read_text(encoding="utf-8", errors="replace")
    target_release = frontmatter_target_release(text)
    for line_no, line in enumerate(text.splitlines(), 1):
        for label, needle in patterns:
            if needle not in line:
                continue
            if is_allowed(label, rel, target_release):
                continue
            hits.append((label, rel, line_no, line.strip()))

if hits:
    print("verify-live-docs: FAIL")
    for label, rel, line_no, line in hits:
        print(f"  {label}: {rel}:{line_no}: {line}")
    raise SystemExit(1)
print("verify-live-docs: PASS")
PY
}

# ---------------------------------------------------------------------------
# strict-p3-commands <manifest> — v1.9.0 draft (Issue #11).
#
# Emits canonical final verification command blocks from the manifest.
# ---------------------------------------------------------------------------
cmd_strict_p3_commands() {
  local manifest="${1:-}" fw
  [[ -n "$manifest" ]] || die "strict-p3-commands requires <manifest-path>"
  fw="$(framework_path_or_self)"
  bash "$fw/scripts/emit-strict-p3-commands.sh" \
    --adopter-root "$repo_root" \
    --framework-root "$fw" \
    "$(abs_path "$manifest")"
}

# ---------------------------------------------------------------------------
# generate-overlays --target codex|claude|gemini|all --out <dir>
#
# Emits generated runtime overlays only. The output is ergonomic and never
# replaces rendered prompt bytes, lifecycle receipts, or verifier evidence.
# ---------------------------------------------------------------------------
cmd_generate_overlays() {
  local fw
  fw="$(framework_path_or_self)"
  [[ -x "$fw/scripts/generate-overlays.sh" ]] \
    || die "generate-overlays requires an installed framework config or a framework checkout with scripts/generate-overlays.sh"
  bash "$fw/scripts/generate-overlays.sh" "$@"
}

# ---------------------------------------------------------------------------
# verify-staging [flags] — v1.7.1 Workstream E.
#
# Inspects git index + working tree + framework-submodule state against
# expected / forbidden paths BEFORE commit. Delegates to
# scripts/verify-staging.sh with the adopter's auto-resolved roots.
# Default: when the framework is installed under .llm-dev/framework,
# auto-forbids staging under that path (the v1.7.1 Workstream A class
# of bug: artifacts landing in the submodule instead of the adopter
# tree). Adopters opt-in to this check by invoking it; legacy adopters
# remain unaffected.
# ---------------------------------------------------------------------------
cmd_verify_staging() {
  local fw
  fw="$(framework_path)"
  bash "$fw/scripts/verify-staging.sh" \
    --adopter-root "$repo_root" \
    --framework-root "$fw" \
    "$@"
}

# ---------------------------------------------------------------------------
# update --to latest|vX.Y.Z|<ref>
# ---------------------------------------------------------------------------
cmd_update() {
  local to_ref="latest" fw repo_url resolved
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --to)
        shift; to_ref="${1:-}"
        ;;
      -h|--help)
        usage; exit 0
        ;;
      *)
        die "unknown update argument: $1"
        ;;
    esac
    shift || true
  done

  [[ -n "$to_ref" ]] || die "update --to requires a ref"
  fw="$(framework_path)"
  repo_url="$(config_get framework_repo_url || true)"
  [[ -n "$repo_url" ]] || repo_url="$(git -C "$fw" remote get-url origin 2>/dev/null || true)"
  [[ -n "$repo_url" ]] || die "no framework_repo_url in config and no origin in framework checkout"

  if [[ "$to_ref" == "latest" ]]; then
    resolved="$(resolve_latest_tag "$repo_url")"
  else
    resolved="$to_ref"
  fi

  checkout_framework_ref "$fw" "$resolved"
  set_config_value framework_ref "$resolved"
  case "$(wrapper_drift_status "$fw")" in
    ok)
      info "adopter wrapper already matches framework copy"
      ;;
    missing-adopter-wrapper:*|drift:*)
      refresh_adopter_wrapper "$fw"
      info "adopter wrapper refreshed at scripts/llm-dev"
      ;;
    missing-framework-wrapper:*)
      die "updated framework checkout does not contain scripts/llm-dev"
      ;;
  esac

  bash "$fw/scripts/verify-schema.sh" >/dev/null
  bash "$fw/scripts/verify-tokens.sh" >/dev/null

  info "framework checkout updated to $resolved"
  info "next: re-validate each adopter manifest you rely on:"
  info "  bash scripts/llm-dev verify <manifest-path>"
  info "next: review and commit changes:"
  info "  git add .gitmodules ${config_path#$repo_root/} \\"
  info "          $(config_required framework_path)"
}

# ---------------------------------------------------------------------------
# agents install
# ---------------------------------------------------------------------------
agents_block() {
  cat <<'BLOCK'
<!-- llm-dev-framework:start -->
## llm-dev-framework Activation

This repo uses `llm-dev-framework` via the repo-local wrapper at
`scripts/llm-dev`. Resolve the framework checkout from
`.llm-dev/config.yaml`; never hard-code an absolute framework path.

Auto-detect rule:
- If `.llm-dev/config.yaml` exists, run `scripts/llm-dev doctor`
  before planning implementation work, then use the wrapper for
  `new <deliverable-id>` / `verify <manifest>` /
  `update --to latest` / `agents install`.
- If `.llm-dev/config.yaml` is absent, only activate the framework
  when the user explicitly asks for `llm-dev-framework`, `/llm-dev`,
  or "install llm-dev-framework". Do not invent the framework into
  unrelated requests.

Managed by `scripts/llm-dev agents install`. Edit content outside
the start/end markers; the block between markers is overwritten on
every refresh. In an AGENTS.md with a preserved `USER CUSTOM`
section, this block lives inside that section so upstream generators
keep it.
<!-- llm-dev-framework:end -->
BLOCK
}

cmd_agents_install() {
  local action="${1:-}" agents_file agents_target agents_dir block_file tmp has_custom link_target
  [[ "$action" == "install" ]] || die "usage: scripts/llm-dev agents install"

  agents_file="$repo_root/AGENTS.md"
  agents_target="$agents_file"
  if [[ -L "$agents_file" ]]; then
    link_target="$(readlink "$agents_file")" || die "could not read AGENTS.md symlink"
    [[ -n "$link_target" ]] || die "AGENTS.md symlink has an empty target"
    case "$link_target" in
      /*) agents_target="$link_target" ;;
      *)
        agents_dir="$(cd "$(dirname "$agents_file")" && pwd)"
        agents_target="$agents_dir/$link_target"
        ;;
    esac
    [[ -e "$agents_target" ]] || die "AGENTS.md symlink target does not exist: $link_target"
    [[ ! -d "$agents_target" ]] || die "AGENTS.md symlink target is a directory: $link_target"
  else
    if [[ -d "$agents_file" ]]; then
      die "AGENTS.md is a directory; refusing to overwrite it"
    fi
    touch "$agents_file"
  fi
  [[ -w "$agents_target" ]] || die "AGENTS.md is not writable: ${agents_target#$repo_root/}"

  block_file="$(mktemp)"
  tmp="$(mktemp)"
  agents_block > "$block_file"
  has_custom="$(
    awk \
      -v custom_start="$CUSTOM_START_MARKER" \
      -v custom_end="$CUSTOM_END_MARKER" '
      function normalized(line) {
        sub(/\r$/, "", line)
        sub(/^[ \t]+/, "", line)
        sub(/[ \t]+$/, "", line)
        return line
      }
      function is_fence(line,  clean) {
        clean = line
        sub(/\r$/, "", clean)
        return clean ~ /^[ \t]*(```|~~~)/
      }
      {
        if (is_fence($0)) {
          in_fence = !in_fence
          next
        }
        if (in_fence) next
        marker = normalized($0)
        if (!in_custom && marker == custom_start) {
          in_custom = 1
          next
        }
        if (in_custom && marker == custom_end) {
          found = 1
          exit
        }
      }
      END { print found ? 1 : 0 }
    ' "$agents_target"
  )"

  awk \
    -v start="$START_MARKER" \
    -v end="$END_MARKER" \
    -v custom_start="$CUSTOM_START_MARKER" \
    -v custom_end="$CUSTOM_END_MARKER" \
    -v has_custom="$has_custom" \
    -v block="$block_file" '
    function flush_pending_blanks(  i) {
      for (i = 0; i < pending_blank_count; i++) print ""
      pending_blank_count = 0
    }
    function normalized(line) {
      sub(/\r$/, "", line)
      sub(/^[ \t]+/, "", line)
      sub(/[ \t]+$/, "", line)
      return line
    }
    function is_fence(line,  clean) {
      clean = line
      sub(/\r$/, "", clean)
      return clean ~ /^[ \t]*(```|~~~)/
    }
    function print_block(  line) {
      while ((getline line < block) > 0) print line
      close(block)
    }
    BEGIN {
      in_block = 0
      in_custom = 0
      inserted = 0
      saw_custom_start = 0
      pending_blank_count = 0
    }
    {
      marker = normalized($0)
    }
    in_block {
      if (marker == end) in_block = 0
      next
    }
    is_fence($0) {
      flush_pending_blanks()
      print
      in_fence = !in_fence
      next
    }
    !in_fence && marker == start {
      if (has_custom && !in_custom) {
        # Stale outside block: drop the blank that preceded it so the
        # migrated USER CUSTOM section stays clean.
        pending_blank_count = 0
        in_block = 1
        next
      }
      flush_pending_blanks()
      print_block()
      in_block = 1
      inserted = 1
      next
    }
    !in_fence && marker == custom_start {
      flush_pending_blanks()
      saw_custom_start = 1
      in_custom = 1
      print
      next
    }
    !in_fence && marker == custom_end {
      if (!inserted && saw_custom_start) {
        print ""
        print_block()
        print ""
        inserted = 1
      }
      in_custom = 0
      print
      next
    }
    has_custom && !in_custom && !in_fence && ($0 == "" || $0 == "\r") {
      pending_blank_count += 1
      next
    }
    { flush_pending_blanks(); print }
    END {
      if (!inserted) {
        flush_pending_blanks()
        if (NR > 0) print ""
        print_block()
      } else {
        flush_pending_blanks()
      }
    }
  ' "$agents_target" > "$tmp"

  cp "$tmp" "$agents_target"
  rm -f "$block_file" "$tmp"
  info "managed AGENTS.md block installed/refreshed at ${agents_file#$repo_root/}"
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------
main() {
  local command="${1:-}"
  shift || true
  case "$command" in
    doctor)             cmd_doctor "$@" ;;
    new)                cmd_new "$@" ;;
    verify)             cmd_verify "$@" ;;
    verify-lifecycle)   cmd_verify_lifecycle "$@" ;;
    verify-staging)     cmd_verify_staging "$@" ;;
    re-adjudication)    cmd_re_adjudication "$@" ;;
    rebind-artifact)    cmd_rebind_artifact "$@" ;;
    post-merge)         cmd_post_merge "$@" ;;
    review-chain)       cmd_review_chain "$@" ;;
    verify-live-docs)   cmd_verify_live_docs "$@" ;;
    strict-p3-commands) cmd_strict_p3_commands "$@" ;;
    generate-overlays)  cmd_generate_overlays "$@" ;;
    update)             cmd_update "$@" ;;
    agents)             cmd_agents_install "$@" ;;
    -h|--help|"")       usage ;;
    *)                  die "unknown command: $command" ;;
  esac
}

main "$@"
